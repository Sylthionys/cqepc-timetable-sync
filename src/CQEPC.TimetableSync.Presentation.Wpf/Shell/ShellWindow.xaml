                                                    ScaleX="1"
                                                    ScaleY="1" />
                                    <TranslateTransform x:Name="PageHostTranslate"
                                                        Y="0" />
                                </TransformGroup>
                            </ContentControl.RenderTransform>
                        </ContentControl>
                    </Grid>
                </Border>
            </ContentControl>
        </Grid>

        <Grid AutomationProperties.AutomationId="Shell.AboutOverlayHost"
              Panel.ZIndex="12"
              Visibility="{Binding IsAboutOverlayOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
              Background="{DynamicResource OverlayBackdropBrush}">
            <views:AboutOverlay Width="640"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                DataContext="{Binding Settings.About}" />
        </Grid>

        <Button Panel.ZIndex="16"
                Margin="0,18,18,0"
                Padding="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                MaxWidth="380"
                Background="Transparent"
                BorderBrush="Transparent"
                Command="{Binding DismissProviderConnectionIssueCommand}"
                Visibility="{Binding ShowProviderConnectionIssue, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ToastRoot"
                            Padding="16,13"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource AccentBrush}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Effect="{StaticResource CardShadowEffect}"
                            Opacity="0.98">
                        <StackPanel>
                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentStrongBrush}"
                                       Text="{Binding ProviderConnectionIssueTitle}" />
                            <TextBlock Margin="0,5,0,0"
                                       FontSize="12"
                                       LineHeight="18"
                                       Foreground="{DynamicResource TextBrush}"
                                       Text="{Binding ProviderConnectionIssueReason}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ToastRoot" Property="BorderBrush" Value="{DynamicResource AccentStrongBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ToastRoot" Property="Opacity" Value="0.9" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <Border Panel.ZIndex="15"
                Margin="0,0,18,18"
                Padding="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                MaxWidth="360"
                Visibility="{Binding ShowTaskCenterNotification, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Expander ExpandDirection="Up"
                      IsExpanded="{Binding IsTaskCenterExpanded, Mode=TwoWay}">
                <Expander.Header>
                    <Border MinWidth="56"
                            Padding="16,12"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource AccentBrush}"
                            BorderThickness="1"
                            CornerRadius="20"
                            Effect="{StaticResource CardShadowEffect}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentStrongBrush}"
                                       Text="{Binding ActiveTaskCount}" />
                            <TextBlock Margin="10,0,0,0"
                                       MaxWidth="230"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"
                                       Text="{Binding ActiveTaskTitle}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                </Expander.Header>
                <Border Margin="0,0,0,12"
                        Padding="12"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="20"
                        Effect="{StaticResource CardShadowEffect}">
                    <ScrollViewer MaxHeight="280"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl AutomationProperties.AutomationId="Shell.TaskCenter.Items"
                                      ItemsSource="{Binding ActiveTasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="12"
                                            Background="{DynamicResource SurfaceAltBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="14">
                                        <TextBlock FontSize="12"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   Text="{Binding Detail}"
                                                   TextWrapping="Wrap" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Expander>
        </Border>

        <Canvas x:Name="ThemeTransitionCanvas"
                Panel.ZIndex="20"
                IsHitTestVisible="False"
                Opacity="0"
                ClipToBounds="True" />
    </Grid>
</Window>
