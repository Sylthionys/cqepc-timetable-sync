<Window x:Class="CQEPC.TimetableSync.Presentation.Wpf.Shell.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:CQEPC.TimetableSync.Presentation.Wpf.Behaviors"
        xmlns:viewModels="clr-namespace:CQEPC.TimetableSync.Presentation.Wpf.ViewModels"
        xmlns:views="clr-namespace:CQEPC.TimetableSync.Presentation.Wpf.Views"
        AutomationProperties.AutomationId="Shell.MainWindow"
        Title="{Binding ApplicationTitle}"
        Width="1380"
        Height="900"
        MinWidth="980"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        behaviors:FileDropBehavior.Command="{Binding HandleDroppedFilesCommand}">
    <Window.InputBindings>
        <KeyBinding Key="Escape"
                    Command="{Binding Settings.About.CloseCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:HomePageViewModel}">
            <views:HomePage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ImportDiffPageViewModel}">
            <views:ImportDiffPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:SettingsPageViewModel}">
            <views:SettingsPage />
        </DataTemplate>

        <Style x:Key="ExpandedSidebarElementStyle" TargetType="{x:Type FrameworkElement}">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SidebarToggleButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SidebarGlyphTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Foreground" Value="{DynamicResource AccentStrongBrush}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SidebarBadgeShellStyle" TargetType="Border">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SidebarCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="11" />
        </Style>

        <Style x:Key="SidebarNavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#00FFFFFF" />
            <Setter Property="BorderBrush" Value="#00FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="MinHeight" Value="54" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter Margin="0"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource StrongBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource HighlightSurfaceBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

        <Grid x:Name="RootGrid"
              Background="{DynamicResource ChromeBackgroundBrush}"
              AutomationProperties.AutomationId="Shell.Root">
        <Ellipse Width="680"
                 Height="680"
                 Margin="-220,-260,0,0"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Fill="{DynamicResource AccentSoftBrush}"
                 Opacity="0.16"
                 IsHitTestVisible="False" />
        <Ellipse Width="520"
                 Height="520"
                 Margin="0,0,-120,-140"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Fill="{DynamicResource AccentMutedBrush}"
                 Opacity="0.45"
                 IsHitTestVisible="False" />

        <Grid Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="168" />
                <ColumnDefinition x:Name="SidebarGapColumn" Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="SidebarHost"
                    Grid.Column="0"
                    AutomationProperties.AutomationId="Shell.Sidebar"
                    Background="{DynamicResource SidebarBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="24"
                    Padding="8"
                    ClipToBounds="True"
                    Effect="{StaticResource CardShadowEffect}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <Grid Margin="2,2,2,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="1"
                                    AutomationProperties.AutomationId="Shell.Sidebar.Toggle"
                                    Style="{StaticResource SidebarToggleButtonStyle}"
                                    Command="{Binding ToggleSidebarCommand}"
                                    Content="{Binding SidebarToggleGlyph}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Margin="0,18,0,0">
                        <Button Style="{StaticResource SidebarNavButtonStyle}"
                                AutomationProperties.AutomationId="Shell.Nav.Home"
                                Tag="{Binding IsHomeSelected}"
                                Command="{Binding ShowHomeCommand}">
                            <Grid Margin="10,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SidebarBadgeShellStyle}">
                                    <TextBlock Style="{StaticResource SidebarGlyphTextStyle}"
                                               Text="{x:Static viewModels:ShellViewModel.HomeGlyph}" />
                                </Border>
                                <TextBlock Grid.Column="2"
                                           VerticalAlignment="Center"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SidebarTextBrush}"
                                           Text="{DynamicResource ShellHomeTitle}"
                                           Style="{StaticResource ExpandedSidebarElementStyle}" />
                            </Grid>
                        </Button>

                        <Button Margin="0,8,0,0"
                                AutomationProperties.AutomationId="Shell.Nav.Import"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Tag="{Binding IsImportSelected}"
                                Command="{Binding ShowImportCommand}">
                            <Grid Margin="10,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SidebarBadgeShellStyle}">
                                    <TextBlock Style="{StaticResource SidebarGlyphTextStyle}"
                                               Text="{x:Static viewModels:ShellViewModel.ImportGlyph}" />
                                </Border>
                                <TextBlock Grid.Column="2"
                                           VerticalAlignment="Center"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SidebarTextBrush}"
                                           Text="{DynamicResource ShellImportTitle}"
                                           Style="{StaticResource ExpandedSidebarElementStyle}" />
                            </Grid>
                        </Button>

                        <Button Margin="0,8,0,0"
                                AutomationProperties.AutomationId="Shell.Nav.Settings"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Tag="{Binding IsSettingsSelected}"
                                Command="{Binding ShowSettingsCommand}">
                            <Grid Margin="10,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SidebarBadgeShellStyle}">
                                    <TextBlock Style="{StaticResource SidebarGlyphTextStyle}"
                                               Text="{x:Static viewModels:ShellViewModel.SettingsGlyph}" />
                                </Border>
                                <TextBlock Grid.Column="2"
                                           VerticalAlignment="Center"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SidebarTextBrush}"
                                           Text="{DynamicResource ShellSettingsTitle}"
                                           Style="{StaticResource ExpandedSidebarElementStyle}" />
                            </Grid>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <ContentControl Grid.Column="2"
                            AutomationProperties.AutomationId="Shell.WorkspaceRoot">
                <Border Background="{DynamicResource WorkspaceBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="28"
                        Padding="6"
                        Effect="{StaticResource CardShadowEffect}">
                    <Grid>
                        <ContentControl AutomationProperties.AutomationId="Shell.PageHost"
                                        Content="{Binding CurrentPageViewModel}">
                        <ContentControl.Resources>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Opacity" Value="0" />
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="16" />
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 To="1"
                                                                 Duration="0:0:0.24"
                                                                 EasingFunction="{StaticResource StandardEase}" />
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                                                 To="0"
                                                                 Duration="0:0:0.24"
                                                                 EasingFunction="{StaticResource StrongEase}" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Resources>
                        </ContentControl>
                    </Grid>
                </Border>
            </ContentControl>
        </Grid>

        <Grid AutomationProperties.AutomationId="Shell.AboutOverlayHost"
              Visibility="{Binding IsAboutOverlayOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
              Background="{DynamicResource OverlayBackdropBrush}">
            <views:AboutOverlay Width="620"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                DataContext="{Binding Settings.About}" />
        </Grid>

        <Canvas x:Name="ThemeTransitionCanvas"
                Panel.ZIndex="20"
                IsHitTestVisible="False"
                ClipToBounds="True">
            <Ellipse x:Name="ThemeTransitionOrb"
                     Width="160"
                     Height="160"
                     Opacity="0"
                     Fill="{DynamicResource WorkspaceBackgroundBrush}">
                <Ellipse.RenderTransform>
                    <ScaleTransform x:Name="ThemeTransitionScale"
                                    ScaleX="0.14"
                                    ScaleY="0.14" />
                </Ellipse.RenderTransform>
            </Ellipse>
        </Canvas>
    </Grid>
</Window>

