<Window x:Class="CQEPC.TimetableSync.Presentation.Wpf.Shell.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:CQEPC.TimetableSync.Presentation.Wpf.Behaviors"
        xmlns:domainEnums="clr-namespace:CQEPC.TimetableSync.Domain.Enums;assembly=CQEPC.TimetableSync.Domain"
        xmlns:viewModels="clr-namespace:CQEPC.TimetableSync.Presentation.Wpf.ViewModels"
        xmlns:views="clr-namespace:CQEPC.TimetableSync.Presentation.Wpf.Views"
        AutomationProperties.AutomationId="Shell.MainWindow"
        Title="{Binding ApplicationTitle}"
        Width="1380"
        Height="900"
        MinWidth="1104"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        behaviors:FileDropBehavior.Command="{Binding HandleDroppedFilesCommand}">
    <Window.InputBindings>
        <KeyBinding Key="Escape"
                    Command="{Binding Settings.ProgramSettings.CloseCommand}" />
        <KeyBinding Key="Escape"
                    Command="{Binding Settings.About.CloseCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:HomePageViewModel}">
            <views:HomePage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ImportDiffPageViewModel}">
            <views:ImportDiffPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:SettingsPageViewModel}">
            <views:SettingsPage />
        </DataTemplate>

        <Style x:Key="ExpandedSidebarElementStyle" TargetType="{x:Type FrameworkElement}">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SidebarToggleButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="HorizontalAlignment" Value="Right" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SidebarGlyphTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Foreground" Value="{DynamicResource AccentStrongBrush}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SidebarBadgeShellStyle" TargetType="Border">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SidebarCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="11" />
        </Style>

        <Style x:Key="NavigationIconRootStyle" TargetType="{x:Type FrameworkElement}">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1"
                                        ScaleY="1" />
                        <RotateTransform Angle="0" />
                        <TranslateTransform X="0"
                                            Y="0" />
                    </TransformGroup>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarNavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#00FFFFFF" />
            <Setter Property="BorderBrush" Value="#00FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="MinHeight" Value="54" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter Margin="0"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource StrongBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource HighlightSurfaceBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarProviderSyncButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="78" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Background" Value="#00FFFFFF" />
            <Setter Property="BorderBrush" Value="#00FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="ToolTip" Value="{Binding Settings.Workspace.CurrentProviderRefreshToolTip}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource StrongBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource HighlightSurfaceBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSettingsSelected}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                                <Setter Property="MinHeight" Value="54" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsSubNavColumnStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSettingsSelected}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsSubNavButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="#00FFFFFF" />
            <Setter Property="BorderBrush" Value="#00FFFFFF" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource SidebarTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="16">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource StrongBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource HighlightSurfaceBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource AccentStrongBrush}" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HighlightSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource AccentStrongBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsSubNavIconRootStyle" TargetType="FrameworkElement">
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1"
                                        ScaleY="1" />
                        <RotateTransform Angle="0" />
                        <TranslateTransform X="0"
                                            Y="0" />
                    </TransformGroup>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsSubNavIconTextStyle" TargetType="TextBlock" BasedOn="{StaticResource SettingsSubNavIconRootStyle}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="FontSize" Value="16" />
        </Style>
    </Window.Resources>

        <Grid x:Name="RootGrid"
              Background="{DynamicResource ChromeBackgroundBrush}"
              AutomationProperties.AutomationId="Shell.Root">
        <Ellipse Width="680"
                 Height="680"
                 Margin="-220,-260,0,0"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Fill="{DynamicResource AccentSoftBrush}"
                 Opacity="0.16"
                 IsHitTestVisible="False" />
        <Ellipse Width="520"
                 Height="520"
                 Margin="0,0,-120,-140"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Fill="{DynamicResource AccentMutedBrush}"
                 Opacity="0.45"
                 IsHitTestVisible="False" />

        <Grid Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="Auto" />
                <ColumnDefinition x:Name="SidebarGapColumn" Width="12" />
                <ColumnDefinition x:Name="SettingsSubNavColumn" Width="Auto" />
                <ColumnDefinition x:Name="SettingsSubNavGapColumn" Width="0" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="SidebarHost"
                    Grid.Column="0"
                    AutomationProperties.AutomationId="Shell.Sidebar"
                    Background="{DynamicResource SidebarBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="24"
                    Padding="8"
                    ClipToBounds="True"
                    Effect="{StaticResource CardShadowEffect}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <Grid Margin="2,2,2,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    AutomationProperties.AutomationId="Shell.Sidebar.Toggle"
                                    Style="{StaticResource SidebarToggleButtonStyle}"
                                    Command="{Binding ToggleSidebarCommand}"
                                    Content="{Binding SidebarToggleGlyph}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Margin="0,18,0,0">
                        <Button Style="{StaticResource SidebarNavButtonStyle}"
                                AutomationProperties.AutomationId="Shell.Nav.Home"
                                Tag="{Binding IsHomeSelected}"
                                Click="HandleNavigationButtonClick"
                                Command="{Binding ShowHomeCommand}">
                            <Grid Margin="10,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SidebarBadgeShellStyle}">
                                    <Canvas Style="{StaticResource NavigationIconRootStyle}"
                                            Tag="AnimatedNavIcon.Home">
                                        <Rectangle Canvas.Left="6.5"
                                                   Canvas.Top="10"
                                                   Width="9"
                                                   Height="8.5"
                                                   RadiusX="1.6"
                                                   RadiusY="1.6"
                                                   Fill="{DynamicResource HighlightSurfaceBrush}"
                                                   Stroke="{DynamicResource AccentStrongBrush}"
                                                   StrokeThickness="1.5" />
                                        <Path Tag="NavHome.Roof"
                                              Stroke="{DynamicResource AccentStrongBrush}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Data="M4,10 L11,4.5 L18,10" />
                                        <Path Stroke="#FFFFFFFF"
                                              StrokeThickness="0.9"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Opacity="0.42"
                                              Data="M6.8,9.5 L11,6.1 L15.2,9.5" />
                                        <Rectangle Canvas.Left="14.1"
                                                   Canvas.Top="6.2"
                                                   Width="1.8"
                                                   Height="3.6"
                                                   RadiusX="0.5"
                                                   RadiusY="0.5"
                                                   Fill="{DynamicResource AccentBrush}"
                                                   Opacity="0.65" />
                                        <Path Stroke="{DynamicResource CalendarGridBrush}"
                                              StrokeThickness="1"
                                              StrokeStartLineCap="Round"
                                              Data="M8.2,12.7 L13.8,12.7 M8.2,15.1 L13.8,15.1 M10.9,10.7 L10.9,18" />
                                        <Rectangle Tag="NavHome.Today"
                                                   Canvas.Left="12.1"
                                                   Canvas.Top="14.2"
                                                   Width="2.8"
                                                   Height="2.8"
                                                   RadiusX="0.8"
                                                   RadiusY="0.8"
                                                   Fill="#2F8A56"
                                                   Opacity="0.36" />
                                        <Rectangle Tag="NavHome.Door"
                                                   Canvas.Left="7.7"
                                                   Canvas.Top="14.1"
                                                   Width="2.5"
                                                   Height="4.3"
                                                   RadiusX="0.8"
                                                   RadiusY="0.8"
                                                   Fill="{DynamicResource AccentBrush}"
                                                   Opacity="0.4" />
                                    </Canvas>
                                </Border>
                                <TextBlock Grid.Column="2"
                                           VerticalAlignment="Center"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SidebarTextBrush}"
                                           Text="{DynamicResource ShellHomeTitle}"
                                           Style="{StaticResource ExpandedSidebarElementStyle}" />
                            </Grid>
                        </Button>

                        <Button Margin="0,8,0,0"
                                AutomationProperties.AutomationId="Shell.Nav.Import"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Tag="{Binding IsImportSelected}"
                                Click="HandleNavigationButtonClick"
                                Command="{Binding ShowImportCommand}">
                            <Grid Margin="10,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SidebarBadgeShellStyle}">
                                    <Canvas Style="{StaticResource NavigationIconRootStyle}"
                                            Tag="AnimatedNavIcon.Import">
                                        <Path Fill="{DynamicResource HighlightSurfaceBrush}"
                                              Stroke="{DynamicResource AccentStrongBrush}"
                                              StrokeThickness="1.5"
                                              StrokeLineJoin="Round"
                                              Data="M6.2,4.2 L13.6,4.2 L16.8,7.5 L16.8,17.8 L6.2,17.8 Z" />
                                        <Path Stroke="{DynamicResource CalendarGridBrush}"
                                              StrokeThickness="1"
                                              StrokeStartLineCap="Round"
                                              Data="M13.5,4.5 L13.5,7.6 L16.6,7.6 M8.3,9.3 L12.6,9.3 M8.3,12 L11.2,12" />
                                        <Path Fill="{DynamicResource AccentBrush}"
                                              Opacity="0.28"
                                              Data="M13.6,4.4 L16.8,7.5 L13.6,7.5 Z" />
                                        <Ellipse Canvas.Left="8.1"
                                                 Canvas.Top="14.1"
                                                 Width="1.8"
                                                 Height="1.8"
                                                 Fill="{DynamicResource SuccessBrush}"
                                                 Opacity="0.7" />
                                        <Path Tag="NavImport.Arrow"
                                              Fill="{DynamicResource AccentBrush}"
                                              Data="M11,9.4 L14.1,12.5 L12.2,12.5 L12.2,16.2 L9.8,16.2 L9.8,12.5 L7.9,12.5 Z" />
                                        <Path Tag="NavImport.Tray"
                                              Stroke="#2F8A56"
                                              StrokeThickness="1.7"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Data="M7.4,18.2 L14.6,18.2" />
                                    </Canvas>
                                </Border>
                                <TextBlock Grid.Column="2"
                                           VerticalAlignment="Center"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SidebarTextBrush}"
                                           Text="{DynamicResource ShellImportTitle}"
                                           Style="{StaticResource ExpandedSidebarElementStyle}" />
                            </Grid>
                        </Button>

                        <Button Margin="0,8,0,0"
                                AutomationProperties.AutomationId="Shell.Nav.Settings"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Tag="{Binding IsSettingsSelected}"
                                Click="HandleNavigationButtonClick"
                                Command="{Binding ShowSettingsCommand}">
                            <Grid Margin="10,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SidebarBadgeShellStyle}">
                                    <Canvas Style="{StaticResource NavigationIconRootStyle}"
                                            Tag="AnimatedNavIcon.Settings">
                                        <Canvas Tag="NavSettings.Gear"
                                                Canvas.Left="2"
                                                Canvas.Top="2"
                                                Width="18"
                                                Height="18"
                                                RenderTransformOrigin="0.5,0.5">
                                            <Rectangle Canvas.Left="7.25"
                                                       Canvas.Top="0.2"
                                                       Width="3.5"
                                                       Height="4.6"
                                                       RadiusX="1.1"
                                                       RadiusY="1.1"
                                                       Fill="{DynamicResource AccentStrongBrush}" />
                                            <Rectangle Canvas.Left="7.25"
                                                       Canvas.Top="13.2"
                                                       Width="3.5"
                                                       Height="4.6"
                                                       RadiusX="1.1"
                                                       RadiusY="1.1"
                                                       Fill="{DynamicResource AccentStrongBrush}" />
                                            <Rectangle Canvas.Left="0.2"
                                                       Canvas.Top="7.25"
                                                       Width="4.6"
                                                       Height="3.5"
                                                       RadiusX="1.1"
                                                       RadiusY="1.1"
                                                       Fill="{DynamicResource AccentStrongBrush}" />
                                            <Rectangle Canvas.Left="13.2"
                                                       Canvas.Top="7.25"
                                                       Width="4.6"
                                                       Height="3.5"
                                                       RadiusX="1.1"
                                                       RadiusY="1.1"
                                                       Fill="{DynamicResource AccentStrongBrush}" />
                                            <Rectangle Canvas.Left="7.25"
                                                       Canvas.Top="0.2"
                                                       Width="3.5"
                                                       Height="4.6"
                                                       RadiusX="1.1"
                                                       RadiusY="1.1"
                                                       Fill="{DynamicResource AccentStrongBrush}"
                                                       RenderTransformOrigin="0.5,1.9">
                                                <Rectangle.RenderTransform>
                                                    <RotateTransform Angle="45" />
                                                </Rectangle.RenderTransform>
                                            </Rectangle>
                                            <Rectangle Canvas.Left="7.25"
                                                       Canvas.Top="0.2"
                                                       Width="3.5"
                                                       Height="4.6"
                                                       RadiusX="1.1"
                                                       RadiusY="1.1"
                                                       Fill="{DynamicResource AccentStrongBrush}"
                                                       RenderTransformOrigin="0.5,1.9">
                                                <Rectangle.RenderTransform>
                                                    <RotateTransform Angle="135" />
                                                </Rectangle.RenderTransform>
                                            </Rectangle>
                                            <Rectangle Canvas.Left="7.25"
                                                       Canvas.Top="0.2"
                                                       Width="3.5"
                                                       Height="4.6"
                                                       RadiusX="1.1"
                                                       RadiusY="1.1"
                                                       Fill="{DynamicResource AccentStrongBrush}"
                                                       RenderTransformOrigin="0.5,1.9">
                                                <Rectangle.RenderTransform>
                                                    <RotateTransform Angle="225" />
                                                </Rectangle.RenderTransform>
                                            </Rectangle>
                                            <Rectangle Canvas.Left="7.25"
                                                       Canvas.Top="0.2"
                                                       Width="3.5"
                                                       Height="4.6"
                                                       RadiusX="1.1"
                                                       RadiusY="1.1"
                                                       Fill="{DynamicResource AccentStrongBrush}"
                                                       RenderTransformOrigin="0.5,1.9">
                                                <Rectangle.RenderTransform>
                                                    <RotateTransform Angle="315" />
                                                </Rectangle.RenderTransform>
                                            </Rectangle>
                                            <Ellipse Canvas.Left="3.5"
                                                     Canvas.Top="3.5"
                                                     Width="11"
                                                     Height="11"
                                                     Fill="{DynamicResource HighlightSurfaceBrush}"
                                                     Stroke="{DynamicResource AccentStrongBrush}"
                                                     StrokeThickness="1.4" />
                                            <Ellipse Canvas.Left="6"
                                                     Canvas.Top="6"
                                                     Width="6"
                                                     Height="6"
                                                     Fill="{DynamicResource SurfaceAltBrush}"
                                                     Stroke="{DynamicResource AccentBrush}"
                                                     StrokeThickness="1.4" />
                                        </Canvas>
                                        <Ellipse Tag="NavSettings.Knob"
                                                 Canvas.Left="10.1"
                                                Canvas.Top="10.1"
                                                Width="1.8"
                                                Height="1.8"
                                                Fill="#2F8A56"
                                                Opacity="0.5" />
                                        <Ellipse Canvas.Left="3.2"
                                                 Canvas.Top="3.2"
                                                 Width="2.3"
                                                 Height="2.3"
                                                 Fill="{DynamicResource WarningBrush}"
                                                 Opacity="0.5" />
                                    </Canvas>
                                </Border>
                                <TextBlock Grid.Column="2"
                                           VerticalAlignment="Center"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SidebarTextBrush}"
                                           Text="{DynamicResource ShellSettingsTitle}"
                                           Style="{StaticResource ExpandedSidebarElementStyle}" />
                            </Grid>
                        </Button>
                    </StackPanel>

                    <Button Grid.Row="2"
                            Margin="0,10,0,2"
                            AutomationProperties.AutomationId="Shell.ProviderSyncStatus"
                            Style="{StaticResource SidebarProviderSyncButtonStyle}"
                            Click="HandleNavigationButtonClick"
                            Command="{Binding RefreshProviderDataCommand}">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Grid Width="42"
                                  Height="42"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Tag="AnimatedNavIcon"
                                  RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="1"
                                                        ScaleY="1" />
                                        <RotateTransform Angle="0" />
                                        <TranslateTransform X="0"
                                                            Y="0" />
                                    </TransformGroup>
                                </Grid.RenderTransform>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Settings.Workspace.IsProviderDataSyncing}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Children[0].ScaleX" To="1.06" Duration="0:0:0.22" EasingFunction="{StaticResource StrongEase}" />
                                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Children[0].ScaleY" To="1.06" Duration="0:0:0.22" EasingFunction="{StaticResource StrongEase}" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
