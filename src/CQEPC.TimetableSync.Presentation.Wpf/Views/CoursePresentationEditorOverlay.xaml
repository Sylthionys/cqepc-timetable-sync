<UserControl x:Class="CQEPC.TimetableSync.Presentation.Wpf.Views.CoursePresentationEditorOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True"
             AutomationProperties.AutomationId="CoursePresentationEditorOverlay.Root">
    <UserControl.Resources>
        <DataTemplate x:Key="CoursePresentationTimeZoneOptionTemplate">
            <TextBlock Text="{Binding DisplayName}" />
        </DataTemplate>
        <DataTemplate x:Key="CoursePresentationColorOptionTemplate">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="12"
                         Height="12"
                         Margin="0,0,8,0"
                         VerticalAlignment="Center"
                         Fill="{Binding ColorHex}"
                         Stroke="{DynamicResource BorderBrush}"
                         StrokeThickness="1" />
                <TextBlock VerticalAlignment="Center"
                           Text="{Binding DisplayName}" />
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Border Padding="24"
            MaxWidth="460"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="26"
            Effect="{StaticResource PopupShadowEffect}">
        <StackPanel>
            <TextBlock Style="{StaticResource EyebrowTextStyle}"
                       Text="{DynamicResource ImportParsedCoursesTitle}" />
            <TextBlock Margin="0,8,0,0"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Text="{Binding Title}" />
            <TextBlock Margin="0,10,0,0"
                       Foreground="{DynamicResource SubtleTextBrush}"
                       Text="{Binding Summary}" />

            <TextBlock Margin="0,20,0,0"
                       FontWeight="SemiBold"
                       Text="{DynamicResource CourseEditorTimeZoneLabel}" />
            <ComboBox Margin="0,8,0,0"
                      x:Name="TimeZoneComboBox"
                      AutomationProperties.AutomationId="CoursePresentationEditor.TimeZoneCombo"
                      ItemTemplate="{StaticResource CoursePresentationTimeZoneOptionTemplate}"
                      ItemsSource="{Binding TimeZoneOptions}"
                      SelectedItem="{Binding SelectedTimeZoneOption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Margin="0,18,0,0"
                       FontWeight="SemiBold"
                       Text="{DynamicResource CourseEditorColorLabel}" />
            <ComboBox Margin="0,8,0,0"
                      AutomationProperties.AutomationId="CoursePresentationEditor.ColorCombo"
                      ItemTemplate="{StaticResource CoursePresentationColorOptionTemplate}"
                      ItemsSource="{Binding ColorOptions}"
                      SelectedItem="{Binding SelectedColorOption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <StackPanel Margin="0,24,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Style="{StaticResource SecondaryButtonStyle}"
                        AutomationProperties.AutomationId="CoursePresentationEditor.CloseButton"
                        Command="{Binding CancelCommand}"
                        Content="{DynamicResource AboutCloseButton}" />
                <Button Margin="10,0,0,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        AutomationProperties.AutomationId="CoursePresentationEditor.ResetButton"
                        Command="{Binding ResetCommand}"
                        Content="{DynamicResource CourseEditorResetButton}"
                        Visibility="{Binding CanReset, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <Button Margin="10,0,0,0"
                        AutomationProperties.AutomationId="CoursePresentationEditor.SaveButton"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding SaveCommand}"
                        Content="{DynamicResource CourseEditorSaveButton}" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
