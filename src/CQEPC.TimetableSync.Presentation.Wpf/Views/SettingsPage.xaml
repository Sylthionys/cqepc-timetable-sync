    <Grid x:Name="RootGrid"
          SizeChanged="HandleRootGridSizeChanged">
    <ScrollViewer AutomationProperties.AutomationId="Settings.PageRoot"
                  VerticalScrollBarVisibility="Auto">
        <Grid x:Name="SettingsLayoutRoot"
