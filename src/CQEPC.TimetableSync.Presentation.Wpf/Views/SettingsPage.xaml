                                  IsChecked="{Binding Workspace.MicrosoftUseBroker, Mode=TwoWay}"
                                  Content="{DynamicResource SettingsMicrosoftUseBrokerTitle}" />
                        <WrapPanel Margin="0,12,0,0">
