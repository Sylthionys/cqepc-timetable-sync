                                <TextBlock VerticalAlignment="Center"
                                           AutomationProperties.AutomationId="Settings.ParsedClassDisplayText"
                                           Foreground="{DynamicResource TextBrush}"
                                           Text="{Binding Workspace.SingleParsedClassName}" />
                            </Border>
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding Workspace.ClassSelectionMessage}" />
