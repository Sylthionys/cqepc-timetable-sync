                                        <ComboBox Margin="0,8,0,0"
                                                  AutomationProperties.AutomationId="ProgramSettings.LocalizationCombo"
                                                  ItemsSource="{Binding Workspace.LocalizationOptions}"
                                                  ItemTemplate="{StaticResource LocalizationOptionTemplate}"
                                                  SelectedItem="{Binding Workspace.SelectedLocalizationOption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock Margin="0,18,0,0"
                                           Style="{StaticResource SettingsComboLabelStyle}"
                                           Text="{Binding Workspace.GoogleTimeZoneSelectionTitle}" />
                                <Grid Margin="0,8,0,0">
                                    <ToggleButton x:Name="GoogleTimeZoneDropDownToggle"
                                                  AutomationProperties.AutomationId="ProgramSettings.GoogleTimeZoneCombo"
                                                  IsChecked="{Binding IsOpen, ElementName=GoogleTimeZonePopup, Mode=TwoWay}"
                                                  Style="{StaticResource TimeZonePickerToggleStyle}">
                                        <TextBlock TextTrimming="CharacterEllipsis"
                                                   Text="{Binding Workspace.SelectedGoogleTimeZoneOption.LocalizedDisplayName}" />
                                    </ToggleButton>

                                    <Popup x:Name="GoogleTimeZonePopup"
                                           AllowsTransparency="True"
                                           Closed="HandleGoogleTimeZonePopupClosed"
                                           DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                           Opened="HandleGoogleTimeZonePopupOpened"
                                           Placement="Bottom"
                                           PlacementTarget="{Binding ElementName=GoogleTimeZoneDropDownToggle}"
                                           StaysOpen="False">
                                        <Border Width="640"
                                                Margin="0,6,0,0"
                                                Padding="12"
                                                Background="{DynamicResource PopupSurfaceBrush}"
                                                BorderBrush="{DynamicResource StrongBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="16">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="12" />
                                                    <RowDefinition Height="280" />
                                                </Grid.RowDefinitions>

                                                <Grid>
                                                    <TextBox x:Name="GoogleTimeZoneSearchBox"
                                                             AutomationProperties.AutomationId="ProgramSettings.GoogleTimeZoneSearchBox"
                                                             InputMethod.IsInputMethodEnabled="True"
                                                             InputMethod.PreferredImeState="On"
                                                             MinHeight="42"
                                                             Padding="12,0"
                                                             Style="{StaticResource TimeZoneSearchBoxStyle}"
                                                             VerticalContentAlignment="Center"
                                                             Text="{Binding Workspace.GoogleTimeZoneSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    <TextBlock Opacity="0.46"
                                                               Text="{Binding Workspace.GoogleTimeZoneSearchPlaceholder}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource SettingsInputPlaceholderTextStyle}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Workspace.HasGoogleTimeZoneSearchText}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>

                                                <Grid Grid.Row="2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="160" />
                                                        <ColumnDefinition Width="12" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Margin="2,0,0,8"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource SubtleTextBrush}"
                                                                   Text="{Binding Workspace.GoogleTimeZoneCategoryLabel}" />
                                                        <ListBox Grid.Row="1"
                                                                 AutomationProperties.AutomationId="ProgramSettings.GoogleTimeZoneCategoryList"
                                                                 ItemContainerStyle="{StaticResource TimeZoneListBoxItemStyle}"
                                                                 ItemTemplate="{StaticResource GoogleTimeZoneCategoryTemplate}"
                                                                 ItemsSource="{Binding Workspace.GoogleTimeZoneCategoryOptions}"
                                                                 SelectedItem="{Binding Workspace.SelectedGoogleTimeZoneCategoryOption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource TimeZoneListBoxStyle}" />
                                                    </Grid>

                                                    <Grid Grid.Column="2">
                                                        <ListBox x:Name="GoogleTimeZoneResultList"
                                                                 AutomationProperties.AutomationId="ProgramSettings.GoogleTimeZoneResultList"
                                                                 ItemContainerStyle="{StaticResource TimeZoneListBoxItemStyle}"
                                                                 ItemTemplate="{StaticResource GoogleTimeZoneOptionTemplate}"
                                                                 ItemsSource="{Binding Workspace.FilteredGoogleTimeZoneOptions}"
                                                                 SelectedItem="{Binding Workspace.SelectedGoogleTimeZoneOption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 SelectionChanged="HandleGoogleTimeZoneResultSelectionChanged"
                                                                 Style="{StaticResource TimeZoneListBoxStyle}" />
                                                        <TextBlock HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource SubtleTextBrush}"
                                                                   Text="{Binding Workspace.GoogleTimeZoneNoResultsText}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Workspace.FilteredGoogleTimeZoneOptions.Count}" Value="0">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </Popup>
                                </Grid>

                                <TextBlock Margin="0,18,0,0"
                                           Style="{StaticResource SettingsComboLabelStyle}"
                                           Text="{Binding Workspace.NetworkProxySelectionTitle}" />
                                <TextBlock Margin="0,6,0,0"
                                           Style="{StaticResource SettingsMetaTextStyle}"
                                           TextWrapping="Wrap"
                                           Text="{Binding Workspace.NetworkProxySelectionSummary}" />
                                <ComboBox Margin="0,8,0,0"
                                          AutomationProperties.AutomationId="ProgramSettings.NetworkProxyCombo"
                                          ItemsSource="{Binding Workspace.NetworkProxyOptions}"
                                          ItemTemplate="{StaticResource NetworkProxyOptionTemplate}"
                                          SelectedItem="{Binding Workspace.SelectedNetworkProxyOption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Border Style="{StaticResource CustomNetworkProxyPanelStyle}"
                                        DataContext="{Binding Workspace}">
                                    <StackPanel>
                                    <Grid>
                                        <TextBox MinHeight="42"
                                                 Padding="12,0"
                                                 VerticalContentAlignment="Center"
                                                 AutomationProperties.AutomationId="ProgramSettings.CustomNetworkProxyUri"
                                                 Text="{Binding CustomNetworkProxyUri, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                        <TextBlock Text="{Binding CustomNetworkProxyPlaceholder}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource SettingsInputPlaceholderTextStyle}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasCustomNetworkProxyUri}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>

                                    <Grid Margin="0,10,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="6" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource SettingsMetaTextStyle}"
                                                   Text="{DynamicResource SettingsProgramProxyUsername}" />
                                        <TextBlock Grid.Column="2"
                                                   Style="{StaticResource SettingsMetaTextStyle}"
                                                   Text="{DynamicResource SettingsProgramProxyPassword}" />
                                        <TextBox Grid.Row="2"
                                                 MinHeight="42"
                                                 Padding="12,0"
                                                 VerticalContentAlignment="Center"
                                                 AutomationProperties.AutomationId="ProgramSettings.CustomNetworkProxyUsername"
                                                 Text="{Binding CustomNetworkProxyUsername, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                        <PasswordBox x:Name="CustomNetworkProxyPasswordBox"
                                                     Grid.Row="2"
                                                     Grid.Column="2"
                                                     MinHeight="42"
                                                     Padding="12,0"
                                                     VerticalContentAlignment="Center"
                                                     AutomationProperties.AutomationId="ProgramSettings.CustomNetworkProxyPassword"
                                                     PasswordChanged="HandleCustomNetworkProxyPasswordChanged" />
                                    </Grid>

                                    <Grid Margin="0,12,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource SettingsMetaTextStyle}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       Text="{DynamicResource SettingsProgramProxyBypassList}" />
                                            <TextBlock Margin="0,3,0,0"
                                                       Style="{StaticResource SettingsMetaTextStyle}"
                                                       TextWrapping="Wrap"
                                                       Text="{DynamicResource SettingsProgramProxyBypassListHelp}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Margin="14,0,8,0"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource SettingsMetaTextStyle}"
                                                   Text="{DynamicResource SettingsProgramProxyBypassLocal}" />
                                        <ToggleButton Grid.Column="2"
                                                      Margin="0"
                                                      VerticalAlignment="Center"
                                                      AutomationProperties.AutomationId="ProgramSettings.CustomNetworkProxyBypassLocal"
                                                      IsChecked="{Binding CustomNetworkProxyBypassLocal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Style="{StaticResource SettingsSwitchStyle}" />
                                        <Grid Grid.Row="2"
                                              Grid.ColumnSpan="2">
                                            <TextBox x:Name="CustomNetworkProxyBypassListBox"
                                                     MinHeight="92"
                                                     Padding="12,10"
                                                     TextWrapping="Wrap"
                                                     AcceptsReturn="True"
                                                     VerticalScrollBarVisibility="Auto"
                                                     AutomationProperties.AutomationId="ProgramSettings.CustomNetworkProxyBypassList"
                                                     Text="{Binding CustomNetworkProxyBypassListText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                            <TextBlock Margin="28,10,12,10"
                                                       Foreground="{DynamicResource SubtleTextBrush}"
                                                       IsHitTestVisible="False"
                                                       Opacity="0.50"
                                                       TextWrapping="Wrap"
                                                       Text="{DynamicResource SettingsProgramProxyBypassListPlaceholder}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Text.Length, ElementName=CustomNetworkProxyBypassListBox}" Value="0">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Grid>
                                    </StackPanel>
                                </Border>
                                <Button Margin="0,10,0,0"
                                        HorizontalAlignment="Left"
                                        AutomationProperties.AutomationId="ProgramSettings.TestNetworkProxyConnection"
                                        Command="{Binding Workspace.TestNetworkProxyConnectionCommand}"
                                        Content="{DynamicResource SettingsProgramProxyTestButton}"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                                <TextBlock Margin="0,6,0,0"
                                           TextWrapping="Wrap"
                                           Text="{Binding Workspace.NetworkProxyConnectionTestStatus}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource SettingsMetaTextStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Workspace.HasNetworkProxyConnectionTestStatus}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border x:Name="ProgramBehaviorCard"
                                Grid.Column="2"
                                Style="{StaticResource SectionCardBorderStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center"
                                               Style="{StaticResource SettingsComboLabelStyle}"
                                               Text="{DynamicResource SettingsProgramSettingsStartupSync}" />
                                    <ToggleButton Grid.Column="1"
                                                  AutomationProperties.AutomationId="ProgramSettings.SyncGoogleOnStartupToggle"
                                                  IsChecked="{Binding Workspace.SyncGoogleCalendarOnStartup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource SettingsSwitchStyle}" />
                                </Grid>

                                <Grid Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center"
                                               Style="{StaticResource SettingsComboLabelStyle}"
                                               Text="{DynamicResource SettingsProgramSettingsStatusNotifications}" />
                                    <ToggleButton Grid.Column="1"
                                                  AutomationProperties.AutomationId="ProgramSettings.StatusNotificationsToggle"
                                                  IsChecked="{Binding Workspace.ShowStatusNotifications, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource SettingsSwitchStyle}" />
                                </Grid>

                                <Grid Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center"
                                               Style="{StaticResource SettingsComboLabelStyle}"
                                               Text="{DynamicResource SettingsProgramLoadCloudCalendarDuringStartup}" />
                                    <ToggleButton Grid.Column="1"
                                                  AutomationProperties.AutomationId="ProgramSettings.LoadCloudCalendarDuringStartupToggle"
                                                  IsChecked="{Binding Workspace.LoadCloudCalendarDuringStartup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource SettingsSwitchStyle}" />
                                </Grid>

                                <Grid Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center"
                                               Style="{StaticResource SettingsComboLabelStyle}"
                                               Text="{DynamicResource SettingsProgramCacheHomeScheduleRendering}" />
                                    <ToggleButton Grid.Column="1"
                                                  AutomationProperties.AutomationId="ProgramSettings.CacheHomeScheduleRenderingToggle"
                                                  IsChecked="{Binding Workspace.CacheHomeScheduleRendering, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource SettingsSwitchStyle}" />
                                </Grid>

                                <Grid Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center"
                                               Style="{StaticResource SettingsComboLabelStyle}"
                                               Text="{DynamicResource SettingsProgramRestoreHomeScheduleRenderingOnStartup}" />
                                    <ToggleButton Grid.Column="1"
                                                  AutomationProperties.AutomationId="ProgramSettings.RestoreHomeScheduleRenderingOnStartupToggle"
                                                  IsChecked="{Binding Workspace.RestoreHomeScheduleRenderingOnStartup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource SettingsSwitchStyle}" />
                                </Grid>

                                <Grid Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center"
                                               Style="{StaticResource SettingsComboLabelStyle}"
                                               Text="{DynamicResource SettingsProgramNotificationDurationTitle}" />
                                    <controls:NumericTextBox Grid.Column="1"
                                                             Margin="12,0,8,0"
                                                             Style="{StaticResource ProgramNumericTextBoxStyle}"
                                                             AutomationProperties.AutomationId="ProgramSettings.NotificationDurationSeconds"
                                                             FallbackValue="3"
                                                             Minimum="1"
                                                             Maximum="15"
                                                             MaxLength="2"
                                                             Text="{Binding Workspace.StatusNotificationDurationSeconds, Mode=TwoWay, UpdateSourceTrigger=LostFocus, FallbackValue=3, TargetNullValue=3}" />
                                    <TextBlock Grid.Column="2"
                                               VerticalAlignment="Center"
                                               Style="{StaticResource SettingsMetaTextStyle}"
                                               Text="{DynamicResource SettingsProgramNotificationDurationUnit}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <StackPanel Margin="0,20,0,0"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal">
                        <ToggleButton Width="64"
                                      Height="64"
                                      Margin="0,0,12,0"
                                      AutomationProperties.AutomationId="ProgramSettings.ThemeToggle"
                                      AutomationProperties.Name="{Binding Workspace.ThemeSelectionTitle}"
                                      ToolTip="{Binding Workspace.ThemeSelectionTitle}"
                                      IsChecked="{Binding Workspace.IsDarkTheme, Mode=TwoWay}"
                                      Style="{StaticResource ThemeToggleButtonStyle}" />
                        <Button Width="64"
                                Height="64"
                                Padding="0"
                                AutomationProperties.AutomationId="ProgramSettings.AboutButton"
                                AutomationProperties.Name="{DynamicResource SettingsAboutButton}"
                                ToolTip="{DynamicResource SettingsAboutButton}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding About.OpenCommand}">
                            <Border Width="28"
                                    Height="28"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource HighlightSurfaceBrush}"
                                    BorderBrush="{DynamicResource StrongBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe UI Semibold"
                                           FontSize="15"
                                           Foreground="{DynamicResource AccentStrongBrush}"
                                           Text="i" />
                            </Border>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </ContentControl>
        </Grid>
    </ScrollViewer>
    </Grid>
</UserControl>
