                        Style="{StaticResource SectionCardBorderStyle}"
                        behaviors:FileDropBehavior.Command="{Binding Workspace.HandleDroppedFilesCommand}">
                    <StackPanel>
                    <ItemsControl
                                  AutomationProperties.AutomationId="Settings.SourceFileCards"
                                  ItemsSource="{Binding Workspace.SourceFiles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ContentControl AutomationProperties.AutomationId="{Binding AutomationId}">
                                    <Border Style="{StaticResource SettingsStatusCardStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Style="{StaticResource CardTitleTextStyle}"
                                                           Text="{Binding Title}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Style="{StaticResource BodyTextStyle}"
                                                           Text="{Binding Description}" />
                                            </StackPanel>

                                            <WrapPanel Grid.Column="1"
                                                       Margin="12,0,0,0"
                                                       VerticalAlignment="Top">
                                                <Border Style="{StaticResource CompactChipBorderStyle}">
                                                    <TextBlock Foreground="{DynamicResource AccentStrongBrush}"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding ImportStatusText}" />
                                                </Border>
                                                <Border Margin="8,0,0,0"
                                                        Style="{StaticResource CompactChipBorderStyle}">
                                                    <TextBlock Foreground="{DynamicResource SubtleTextBrush}"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding ParseStatusText}" />
                                                </Border>
                                            </WrapPanel>

                                            <Border Grid.Row="1"
                                                    Grid.ColumnSpan="2"
                                                    Margin="0,12,0,0"
                                                    Padding="12"
                                                    Background="{DynamicResource SurfaceBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="14">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock FontWeight="SemiBold"
                                                                   Text="{Binding SelectedFileName}" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   Style="{StaticResource SettingsMetaTextStyle}"
                                                                   Text="{Binding LastSelectedSummary}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <WrapPanel Grid.Row="2"
                                                       Grid.ColumnSpan="2"
                                                       Margin="0,12,0,0">
                                                <Button MinWidth="96"
                                                        Padding="14,8"
                                                        AutomationProperties.AutomationId="{Binding BrowseAutomationId}"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Command="{Binding BrowseCommand}"
                                                        Content="{DynamicResource SettingsBrowseButton}" />
                                                <Button MinWidth="96"
                                                        Margin="8,0,0,0"
                                                        Padding="14,8"
                                                        AutomationProperties.AutomationId="{Binding RemoveAutomationId}"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Command="{Binding RemoveCommand}"
                                                        Content="{DynamicResource SettingsRemoveButton}" />
                                            </WrapPanel>
                                        </Grid>
                                    </Border>
                                </ContentControl>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    </StackPanel>
                </Border>
            </ContentControl>

            <ContentControl x:Name="TimetableSection"
                            AutomationProperties.AutomationId="Settings.TimetableResolutionSection"
                            Style="{StaticResource VisibleForTimetableSectionStyle}">
                <Border Margin="0,18,0,0"
                        Style="{StaticResource SectionCardBorderStyle}">
