<UserControl x:Class="CQEPC.TimetableSync.Presentation.Wpf.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:CQEPC.TimetableSync.Presentation.Wpf.Behaviors"
             xmlns:controls="clr-namespace:CQEPC.TimetableSync.Presentation.Wpf.Controls"
             xmlns:resources="clr-namespace:CQEPC.TimetableSync.Presentation.Wpf.Resources">
    <UserControl.Resources>
        <DataTemplate x:Key="StringComboTemplate">
            <TextBlock VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Text="{Binding}" />
        </DataTemplate>

        <DataTemplate x:Key="TimeProfileOptionTemplate">
            <TextBlock VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Text="{Binding DisplayName}" />
        </DataTemplate>

        <DataTemplate x:Key="TimeProfileModeOptionTemplate">
            <TextBlock VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Text="{Binding DisplayName}" />
        </DataTemplate>

        <DataTemplate x:Key="ProviderOptionTemplate">
            <TextBlock VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Text="{Binding DisplayName}" />
        </DataTemplate>

        <DataTemplate x:Key="WeekStartOptionTemplate">
            <TextBlock VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Text="{Binding DisplayName}" />
        </DataTemplate>

        <DataTemplate x:Key="LocalizationOptionTemplate">
            <TextBlock VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Text="{Binding DisplayName}" />
        </DataTemplate>

        <DataTemplate x:Key="NetworkProxyOptionTemplate">
            <TextBlock VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Text="{Binding DisplayName}" />
        </DataTemplate>

        <DataTemplate x:Key="GoogleTimeZoneOptionTemplate">
            <TextBlock VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Text="{Binding LocalizedDisplayName}" />
        </DataTemplate>

        <DataTemplate x:Key="GoogleTimeZoneCategoryTemplate">
            <TextBlock VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Text="{Binding DisplayName}" />
        </DataTemplate>

        <DataTemplate x:Key="GoogleCalendarColorOptionTemplate">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="12"
                         Height="12"
                         Margin="0,0,8,0"
                         VerticalAlignment="Center"
                         Fill="{Binding ColorHex}"
                         Stroke="{DynamicResource BorderBrush}"
                         StrokeThickness="1" />
                <TextBlock VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Text="{Binding DisplayName}" />
            </StackPanel>
        </DataTemplate>

        <Style x:Key="CenteredComboBoxItemStyle" TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="TextBlock.TextAlignment" Value="Center" />
        </Style>

        <Style x:Key="CenteredSettingsComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="TextBlock.TextAlignment" Value="Center" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource CenteredComboBoxItemStyle}" />
        </Style>

        <Style TargetType="ComboBox" BasedOn="{StaticResource CenteredSettingsComboBoxStyle}" />

        <Style x:Key="TimeZonePickerToggleStyle" TargetType="ToggleButton">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="MinHeight" Value="46" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <Grid Margin="{TemplateBinding Padding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter VerticalAlignment="Center"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                                <TextBlock Grid.Column="1"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           Text="v" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource StrongBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TimeZoneSearchBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Background" Value="{DynamicResource PopupAltSurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}" />
            <Setter Property="SelectionBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="SelectionTextBrush" Value="White" />
        </Style>

        <Style x:Key="TimeZoneListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style x:Key="TimeZoneListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource PopupHighlightBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource PopupSelectedBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.48" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProgramNumericTextBoxStyle"
               TargetType="controls:NumericTextBox"
               BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Width" Value="76" />
            <Setter Property="MinHeight" Value="48" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Validation.ErrorTemplate" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="controls:NumericTextBox">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource StrongBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="Validation.HasError" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsStatusCardStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        <Style x:Key="SettingsComboLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>

        <Style x:Key="SettingsMetaTextStyle" TargetType="TextBlock" BasedOn="{StaticResource MetaTextStyle}">
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="SettingsSurfacePanelStyle" TargetType="Border">
            <Setter Property="Padding" Value="16" />
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        <Style x:Key="SettingsInputPlaceholderTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="28,0,12,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource SubtleTextBrush}" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Opacity" Value="0.50" />
        </Style>

        <Style x:Key="CustomNetworkProxyPanelStyle" TargetType="Border" BasedOn="{StaticResource SettingsSurfacePanelStyle}">
            <Setter Property="Margin" Value="0,10,0,0" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCustomNetworkProxySelected}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="VisibleWhenTrueStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="VisibleWhenFalseStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StaticSelectionFieldStyle" TargetType="Border">
            <Setter Property="MinHeight" Value="48" />
            <Setter Property="Padding" Value="16,11" />
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
        </Style>

        <Style x:Key="ThemeToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="64" />
            <Setter Property="Height" Value="64" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource StrongBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="32">
                            <Grid>
                                <Ellipse x:Name="ThemeButtonGlow"
                                         Width="58"
                                         Height="30"
                                         Margin="0,0,0,8"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Bottom"
                                         Opacity="0"
                                         RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.Fill>
                                        <RadialGradientBrush Center="0.5,0.5"
                                                             GradientOrigin="0.5,0.5"
                                                             RadiusX="0.56"
                                                             RadiusY="0.5">
                                            <GradientStop Color="#66FFD782"
                                                          Offset="0" />
                                            <GradientStop Color="#22FFB14A"
                                                          Offset="0.62" />
                                            <GradientStop Color="#00FFB14A"
                                                          Offset="1" />
                                        </RadialGradientBrush>
                                    </Ellipse.Fill>
                                    <Ellipse.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="0.66"
                                                            ScaleY="0.54" />
                                            <TranslateTransform Y="6" />
                                        </TransformGroup>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                                <Viewbox x:Name="SunIcon"
                                         Width="24"
                                         Height="24"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         RenderTransformOrigin="0.5,0.5">
                                    <Viewbox.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="1"
                                                            ScaleY="1" />
                                            <RotateTransform Angle="0" />
                                            <TranslateTransform X="0"
                                                                Y="0" />
                                        </TransformGroup>
                                    </Viewbox.RenderTransform>
                                    <Canvas Width="24"
                                            Height="24">
                                        <Ellipse Width="8"
                                                 Height="8"
                                                 Canvas.Left="8"
                                                 Canvas.Top="8"
                                                 Stroke="{DynamicResource AccentStrongBrush}"
                                                 StrokeThickness="2"
                                                 Fill="Transparent" />
                                        <Line X1="12" Y1="1.5" X2="12" Y2="4.5" Stroke="{DynamicResource AccentStrongBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                        <Line X1="12" Y1="19.5" X2="12" Y2="22.5" Stroke="{DynamicResource AccentStrongBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                        <Line X1="1.5" Y1="12" X2="4.5" Y2="12" Stroke="{DynamicResource AccentStrongBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                        <Line X1="19.5" Y1="12" X2="22.5" Y2="12" Stroke="{DynamicResource AccentStrongBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                        <Line X1="4.6" Y1="4.6" X2="6.7" Y2="6.7" Stroke="{DynamicResource AccentStrongBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                        <Line X1="17.3" Y1="17.3" X2="19.4" Y2="19.4" Stroke="{DynamicResource AccentStrongBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                        <Line X1="19.4" Y1="4.6" X2="17.3" Y2="6.7" Stroke="{DynamicResource AccentStrongBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                        <Line X1="6.7" Y1="17.3" X2="4.6" Y2="19.4" Stroke="{DynamicResource AccentStrongBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <Viewbox x:Name="MoonIcon"
                                         Width="24"
                                         Height="24"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         Opacity="0"
                                         RenderTransformOrigin="0.5,0.5">
                                    <Viewbox.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="0.82"
                                                            ScaleY="0.82" />
                                            <RotateTransform Angle="-18" />
                                            <TranslateTransform X="-8"
                                                                Y="18" />
                                        </TransformGroup>
                                    </Viewbox.RenderTransform>
                                    <Path Width="24"
                                          Height="24"
                                          Data="M21 12.8A9 9 0 1 1 11.2 3A7 7 0 0 0 21 12.8Z"
                                          Fill="Transparent"
                                          Stroke="{DynamicResource AccentStrongBrush}"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round" />
                                </Viewbox>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource HighlightSurfaceBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource HighlightSurfaceBrush}" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SunIcon" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2" EasingFunction="{StaticResource StandardEase}" />
                                            <DoubleAnimation Storyboard.TargetName="SunIcon" Storyboard.TargetProperty="RenderTransform.Children[0].ScaleX" To="0.72" Duration="0:0:0.24" EasingFunction="{StaticResource StandardEase}" />
                                            <DoubleAnimation Storyboard.TargetName="SunIcon" Storyboard.TargetProperty="RenderTransform.Children[0].ScaleY" To="0.72" Duration="0:0:0.24" EasingFunction="{StaticResource StandardEase}" />
                                            <DoubleAnimation Storyboard.TargetName="SunIcon" Storyboard.TargetProperty="RenderTransform.Children[1].Angle" To="34" Duration="0:0:0.24" EasingFunction="{StaticResource StandardEase}" />
                                            <DoubleAnimation Storyboard.TargetName="SunIcon" Storyboard.TargetProperty="RenderTransform.Children[2].X" To="8" Duration="0:0:0.34" EasingFunction="{StaticResource StandardEase}" />
                                            <DoubleAnimation Storyboard.TargetName="SunIcon" Storyboard.TargetProperty="RenderTransform.Children[2].Y" To="18" Duration="0:0:0.3" EasingFunction="{StaticResource StandardEase}" />
                                            <DoubleAnimation Storyboard.TargetName="MoonIcon" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.24" EasingFunction="{StaticResource StandardEase}" />
                                            <DoubleAnimation Storyboard.TargetName="MoonIcon" Storyboard.TargetProperty="RenderTransform.Children[0].ScaleX" To="1" Duration="0:0:0.24" EasingFunction="{StaticResource StrongEase}" />
                                            <DoubleAnimation Storyboard.TargetName="MoonIcon" Storyboard.TargetProperty="RenderTransform.Children[0].ScaleY" To="1" Duration="0:0:0.24" EasingFunction="{StaticResource StrongEase}" />
                                            <DoubleAnimation Storyboard.TargetName="MoonIcon" Storyboard.TargetProperty="RenderTransform.Children[1].Angle" To="0" Duration="0:0:0.24" EasingFunction="{StaticResource StrongEase}" />
                                            <DoubleAnimation Storyboard.TargetName="MoonIcon" Storyboard.TargetProperty="RenderTransform.Children[2].X" To="0" Duration="0:0:0.34" EasingFunction="{StaticResource StrongEase}" />
                                            <DoubleAnimation Storyboard.TargetName="MoonIcon" Storyboard.TargetProperty="RenderTransform.Children[2].Y" To="0" Duration="0:0:0.3" EasingFunction="{StaticResource StrongEase}" />
                                            <DoubleAnimation Storyboard.TargetName="ThemeButtonGlow" Storyboard.TargetProperty="Opacity" From="0" To="0.32" Duration="0:0:0.2" AutoReverse="True" EasingFunction="{StaticResource StandardEase}" />
                                            <DoubleAnimation Storyboard.TargetName="ThemeButtonGlow" Storyboard.TargetProperty="RenderTransform.Children[0].ScaleX" From="0.66" To="1.1" Duration="0:0:0.4" EasingFunction="{StaticResource StandardEase}" />
                                            <DoubleAnimation Storyboard.TargetName="ThemeButtonGlow" Storyboard.TargetProperty="RenderTransform.Children[0].ScaleY" From="0.54" To="0.76" Duration="0:0:0.4" EasingFunction="{StaticResource StandardEase}" />
                                            <DoubleAnimation Storyboard.TargetName="ThemeButtonGlow" Storyboard.TargetProperty="RenderTransform.Children[1].Y" From="6" To="-2" Duration="0:0:0.4" EasingFunction="{StaticResource StandardEase}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="MoonIcon" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2" EasingFunction="{StaticResource StandardEase}" />
                                            <DoubleAnimation Storyboard.TargetName="MoonIcon" Storyboard.TargetProperty="RenderTransform.Children[0].ScaleX" To="0.82" Duration="0:0:0.24" EasingFunction="{StaticResource StandardEase}" />
                                            <DoubleAnimation Storyboard.TargetName="MoonIcon" Storyboard.TargetProperty="RenderTransform.Children[0].ScaleY" To="0.82" Duration="0:0:0.24" EasingFunction="{StaticResource StandardEase}" />
                                            <DoubleAnimation Storyboard.TargetName="MoonIcon" Storyboard.TargetProperty="RenderTransform.Children[1].Angle" To="-18" Duration="0:0:0.24" EasingFunction="{StaticResource StandardEase}" />
                                            <DoubleAnimation Storyboard.TargetName="MoonIcon" Storyboard.TargetProperty="RenderTransform.Children[2].X" To="-8" Duration="0:0:0.34" EasingFunction="{StaticResource StandardEase}" />
                                            <DoubleAnimation Storyboard.TargetName="MoonIcon" Storyboard.TargetProperty="RenderTransform.Children[2].Y" To="18" Duration="0:0:0.3" EasingFunction="{StaticResource StandardEase}" />
                                            <DoubleAnimation Storyboard.TargetName="SunIcon" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.24" EasingFunction="{StaticResource StandardEase}" />
                                            <DoubleAnimation Storyboard.TargetName="SunIcon" Storyboard.TargetProperty="RenderTransform.Children[0].ScaleX" To="1" Duration="0:0:0.24" EasingFunction="{StaticResource StrongEase}" />
                                            <DoubleAnimation Storyboard.TargetName="SunIcon" Storyboard.TargetProperty="RenderTransform.Children[0].ScaleY" To="1" Duration="0:0:0.24" EasingFunction="{StaticResource StrongEase}" />
                                            <DoubleAnimation Storyboard.TargetName="SunIcon" Storyboard.TargetProperty="RenderTransform.Children[1].Angle" To="0" Duration="0:0:0.24" EasingFunction="{StaticResource StrongEase}" />
                                            <DoubleAnimation Storyboard.TargetName="SunIcon" Storyboard.TargetProperty="RenderTransform.Children[2].X" To="0" Duration="0:0:0.34" EasingFunction="{StaticResource StrongEase}" />
                                            <DoubleAnimation Storyboard.TargetName="SunIcon" Storyboard.TargetProperty="RenderTransform.Children[2].Y" To="0" Duration="0:0:0.3" EasingFunction="{StaticResource StrongEase}" />
                                            <DoubleAnimation Storyboard.TargetName="ThemeButtonGlow" Storyboard.TargetProperty="Opacity" From="0" To="0.32" Duration="0:0:0.2" AutoReverse="True" EasingFunction="{StaticResource StandardEase}" />
                                            <DoubleAnimation Storyboard.TargetName="ThemeButtonGlow" Storyboard.TargetProperty="RenderTransform.Children[0].ScaleX" From="0.66" To="1.1" Duration="0:0:0.4" EasingFunction="{StaticResource StandardEase}" />
                                            <DoubleAnimation Storyboard.TargetName="ThemeButtonGlow" Storyboard.TargetProperty="RenderTransform.Children[0].ScaleY" From="0.54" To="0.76" Duration="0:0:0.4" EasingFunction="{StaticResource StandardEase}" />
                                            <DoubleAnimation Storyboard.TargetName="ThemeButtonGlow" Storyboard.TargetProperty="RenderTransform.Children[1].Y" From="6" To="-2" Duration="0:0:0.4" EasingFunction="{StaticResource StandardEase}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsMiniActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Width" Value="64" />
            <Setter Property="Height" Value="64" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Normal" />
        </Style>

        <Style x:Key="SettingsSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="62" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource StrongBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Track"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="17" />
                            <Ellipse x:Name="Thumb"
                                     Width="26"
                                     Height="26"
                                     Margin="4,0,0,0"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Fill="{DynamicResource AccentStrongBrush}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="Thumb" Property="Fill" Value="White" />
                                <Setter TargetName="Thumb" Property="Margin" Value="32,0,0,0" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetName="Thumb"
                                                                Storyboard.TargetProperty="Margin"
                                                                To="32,0,0,0"
                                                                Duration="0:0:0.2"
                                                                EasingFunction="{StaticResource StrongEase}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetName="Thumb"
                                                                Storyboard.TargetProperty="Margin"
                                                                To="4,0,0,0"
                                                                Duration="0:0:0.2"
                                                                EasingFunction="{StaticResource StrongEase}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.46" />
                                <Setter TargetName="Thumb" Property="Opacity" Value="0.46" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

