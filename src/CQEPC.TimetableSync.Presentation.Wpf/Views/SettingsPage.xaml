                                        AutomationProperties.AutomationId="Settings.FirstWeekStartDatePicker"
                                        SelectedDate="{Binding Workspace.EffectiveFirstWeekStartDate, Mode=TwoWay}" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding Workspace.FirstWeekStartResolutionSummary}" />
                            <Button Margin="0,10,0,0"
                                    HorizontalAlignment="Left"
                                    AutomationProperties.AutomationId="Settings.UseXlsDateButton"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding Workspace.UseAutoDerivedFirstWeekStartCommand}"
