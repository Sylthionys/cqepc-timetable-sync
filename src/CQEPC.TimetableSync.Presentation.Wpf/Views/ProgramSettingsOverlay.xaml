<UserControl x:Class="CQEPC.TimetableSync.Presentation.Wpf.Views.ProgramSettingsOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AutomationProperties.AutomationId="ProgramSettingsOverlay.Root">
    <UserControl.Resources>
        <DataTemplate x:Key="ProgramSettingsWeekStartOptionTemplate">
            <TextBlock Text="{Binding DisplayName}" />
        </DataTemplate>

        <DataTemplate x:Key="ProgramSettingsLocalizationOptionTemplate">
            <TextBlock Text="{Binding DisplayName}" />
        </DataTemplate>

        <DataTemplate x:Key="ProgramSettingsNetworkProxyOptionTemplate">
            <TextBlock Text="{Binding DisplayName}" />
        </DataTemplate>

        <DataTemplate x:Key="ProgramSettingsGoogleTimeZoneOptionTemplate">
            <TextBlock TextTrimming="CharacterEllipsis"
                       Text="{Binding LocalizedDisplayName}" />
        </DataTemplate>

        <DataTemplate x:Key="ProgramSettingsGoogleTimeZoneCategoryTemplate">
            <TextBlock TextTrimming="CharacterEllipsis"
                       Text="{Binding DisplayName}" />
        </DataTemplate>

        <Style x:Key="ProgramSettingsTimeZoneListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style x:Key="ProgramSettingsTimeZoneListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource PopupHighlightBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource PopupSelectedBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.48" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProgramSettingsPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="32" />
            <Setter Property="Padding" Value="28" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="14" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             To="1"
                                             Duration="0:0:0.24"
                                             EasingFunction="{StaticResource StandardEase}" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                             To="0"
                                             Duration="0:0:0.24"
                                             EasingFunction="{StaticResource StrongEase}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ProgramSettingsCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="24" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="ProgramSettingsInputPlaceholderTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="28,0,12,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource SubtleTextBrush}" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Opacity" Value="0.52" />
        </Style>

        <Style x:Key="ProgramSettingsVisibleWhenTrueStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ProgramSettingsTimeZonePickerToggleStyle" TargetType="ToggleButton">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="MinHeight" Value="46" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <Grid Margin="{TemplateBinding Padding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter VerticalAlignment="Center"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                                <TextBlock Grid.Column="1"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           Text="v" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource StrongBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProgramSettingsSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="54" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource StrongBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Track"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="16" />
                            <Ellipse x:Name="Thumb"
                                     Width="24"
                                     Height="24"
                                     Margin="4,0,0,0"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Fill="{DynamicResource SurfaceBrush}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="Thumb" Property="Fill" Value="{DynamicResource AccentTextBrush}" />
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,4,0" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.84" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.46" />
                                <Setter TargetName="Thumb" Property="Opacity" Value="0.46" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProgramSettingsThemeToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="56" />
            <Setter Property="Height" Value="56" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource StrongBorderBrush}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1"
                                                ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="{DynamicResource HighlightSurfaceBrush}" />
                                <Setter TargetName="Root"
                                        Property="BorderBrush"
                                        Value="{DynamicResource StrongBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Root"
                                        Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97"
                                                        ScaleY="0.97" />
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Root"
                                        Property="Opacity"
                                        Value="0.96" />
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter TargetName="Root"
                                        Property="Opacity"
                                        Value="0.46" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Style="{StaticResource PageRootStyle}">
        <Grid>
            <Ellipse Width="480"
                     Height="480"
                     Margin="-160,-180,0,0"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Fill="{DynamicResource AccentSoftBrush}"
                     Opacity="0.26"
                     IsHitTestVisible="False" />
            <Ellipse Width="360"
                     Height="360"
                     Margin="0,0,-120,-120"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Bottom"
                     Fill="{DynamicResource AccentMutedBrush}"
                     Opacity="0.7"
                     IsHitTestVisible="False" />
        </Grid>

        <Border Width="640"
                MaxWidth="640"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Style="{StaticResource ProgramSettingsPanelStyle}"
                Effect="{StaticResource PopupShadowEffect}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource EyebrowTextStyle}"
                                   Text="{DynamicResource SettingsProgramSettingsButton}" />
                        <TextBlock Margin="0,10,0,0"
                                   FontSize="31"
                                   FontWeight="SemiBold"
                                   Text="{DynamicResource SettingsProgramSettingsTitle}" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            AutomationProperties.AutomationId="ProgramSettingsOverlay.Close"
                            MinWidth="92"
                            Height="40"
                            VerticalAlignment="Top"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding CloseCommand}"
                            Content="{DynamicResource AboutCloseButton}" />
                </Grid>

                <Grid Grid.Row="1"
                      Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource ProgramSettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource EyebrowTextStyle}"
                                       Text="{DynamicResource SettingsWeekStartsOnTitle}" />
                            <ComboBox Margin="0,14,0,0"
                                      AutomationProperties.AutomationId="ProgramSettings.WeekStartCombo"
                                      ItemsSource="{Binding Workspace.WeekStartOptions}"
                                      ItemTemplate="{StaticResource ProgramSettingsWeekStartOptionTemplate}"
                                      SelectedItem="{Binding Workspace.SelectedWeekStartOption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource ProgramSettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource EyebrowTextStyle}"
                                       Text="{Binding Workspace.LanguageSelectionTitle}" />
                            <ComboBox Margin="0,14,0,0"
                                      AutomationProperties.AutomationId="ProgramSettings.LocalizationCombo"
                                      ItemsSource="{Binding Workspace.LocalizationOptions}"
                                      ItemTemplate="{StaticResource ProgramSettingsLocalizationOptionTemplate}"
                                      SelectedItem="{Binding Workspace.SelectedLocalizationOption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.ColumnSpan="3"
                            Margin="0,14,0,0"
                            Style="{StaticResource ProgramSettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource EyebrowTextStyle}"
                                       Text="{Binding Workspace.GoogleTimeZoneSelectionTitle}" />
                            <Grid Margin="0,14,0,0">
                                <ToggleButton x:Name="ProgramGoogleTimeZoneDropDownToggle"
                                              AutomationProperties.AutomationId="ProgramSettings.GoogleTimeZoneCombo"
                                              IsChecked="{Binding IsOpen, ElementName=ProgramGoogleTimeZonePopup, Mode=TwoWay}"
                                              Style="{StaticResource ProgramSettingsTimeZonePickerToggleStyle}">
                                    <TextBlock TextTrimming="CharacterEllipsis"
                                               Text="{Binding Workspace.SelectedGoogleTimeZoneOption.LocalizedDisplayName}" />
                                </ToggleButton>

                                <Popup x:Name="ProgramGoogleTimeZonePopup"
                                       AllowsTransparency="True"
                                       Closed="HandleGoogleTimeZonePopupClosed"
                                       DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                       Opened="HandleGoogleTimeZonePopupOpened"
                                       Placement="Bottom"
                                       PlacementTarget="{Binding ElementName=ProgramGoogleTimeZoneDropDownToggle}"
                                       StaysOpen="False">
                                    <Border Width="640"
                                            Margin="0,6,0,0"
                                            Padding="12"
                                            Background="{DynamicResource PopupSurfaceBrush}"
                                            BorderBrush="{DynamicResource StrongBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="16"
                                            Effect="{StaticResource PopupShadowEffect}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="280" />
                                            </Grid.RowDefinitions>

                                            <Grid>
                                                <TextBox x:Name="ProgramGoogleTimeZoneSearchBox"
                                                         AutomationProperties.AutomationId="ProgramSettings.GoogleTimeZoneSearchBox"
                                                         Background="{DynamicResource PopupAltSurfaceBrush}"
                                                         BorderBrush="{DynamicResource BorderBrush}"
                                                         CaretBrush="{DynamicResource TextBrush}"
                                                         Foreground="{DynamicResource TextBrush}"
                                                         InputMethod.IsInputMethodEnabled="True"
                                                         InputMethod.PreferredImeState="On"
                                                         MinHeight="42"
                                                         Padding="12,0"
                                                         SelectionBrush="{DynamicResource AccentBrush}"
                                                         SelectionTextBrush="White"
                                                         VerticalContentAlignment="Center"
                                                         Text="{Binding Workspace.GoogleTimeZoneSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Opacity="0.52"
                                                           Text="{Binding Workspace.GoogleTimeZoneSearchPlaceholder}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource ProgramSettingsInputPlaceholderTextStyle}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Workspace.HasGoogleTimeZoneSearchText}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>

                                            <Grid Grid.Row="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="160" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="*" />
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Margin="2,0,0,8"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource SubtleTextBrush}"
                                                               Text="{Binding Workspace.GoogleTimeZoneCategoryLabel}" />
                                                    <ListBox Grid.Row="1"
                                                             AutomationProperties.AutomationId="ProgramSettings.GoogleTimeZoneCategoryList"
                                                             ItemContainerStyle="{StaticResource ProgramSettingsTimeZoneListBoxItemStyle}"
                                                             ItemTemplate="{StaticResource ProgramSettingsGoogleTimeZoneCategoryTemplate}"
                                                             ItemsSource="{Binding Workspace.GoogleTimeZoneCategoryOptions}"
                                                             SelectedItem="{Binding Workspace.SelectedGoogleTimeZoneCategoryOption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource ProgramSettingsTimeZoneListBoxStyle}" />
                                                </Grid>

                                                <Grid Grid.Column="2">
                                                    <ListBox AutomationProperties.AutomationId="ProgramSettings.GoogleTimeZoneResultList"
                                                             ItemContainerStyle="{StaticResource ProgramSettingsTimeZoneListBoxItemStyle}"
                                                             ItemTemplate="{StaticResource ProgramSettingsGoogleTimeZoneOptionTemplate}"
                                                             ItemsSource="{Binding Workspace.FilteredGoogleTimeZoneOptions}"
                                                             SelectedItem="{Binding Workspace.SelectedGoogleTimeZoneOption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             SelectionChanged="HandleGoogleTimeZoneResultSelectionChanged"
                                                             Style="{StaticResource ProgramSettingsTimeZoneListBoxStyle}" />
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource SubtleTextBrush}"
                                                               Text="{Binding Workspace.GoogleTimeZoneNoResultsText}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Workspace.FilteredGoogleTimeZoneOptions.Count}" Value="0">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Popup>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2"
                            Style="{StaticResource ProgramSettingsCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       Style="{StaticResource EyebrowTextStyle}"
                                       Text="{DynamicResource SettingsProgramSettingsStartupSync}" />
                            <ToggleButton Grid.Column="1"
                                          AutomationProperties.AutomationId="ProgramSettings.SyncGoogleOnStartupToggle"
                                          IsChecked="{Binding Workspace.SyncGoogleCalendarOnStartup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Style="{StaticResource ProgramSettingsSwitchStyle}" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Grid.Column="2"
                            Style="{StaticResource ProgramSettingsCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       Style="{StaticResource EyebrowTextStyle}"
                                       Text="{DynamicResource SettingsProgramSettingsStatusNotifications}" />
                            <ToggleButton Grid.Column="1"
                                          AutomationProperties.AutomationId="ProgramSettings.StatusNotificationsToggle"
                                          IsChecked="{Binding Workspace.ShowStatusNotifications, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Style="{StaticResource ProgramSettingsSwitchStyle}" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="3"
                            Grid.ColumnSpan="3"
                            Margin="0,14,0,0"
                            Style="{StaticResource ProgramSettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource EyebrowTextStyle}"
                                       Text="{Binding Workspace.NetworkProxySelectionTitle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding Workspace.NetworkProxySelectionSummary}" />
                            <ComboBox Margin="0,12,0,0"
                                      AutomationProperties.AutomationId="ProgramSettings.NetworkProxyCombo"
                                      ItemsSource="{Binding Workspace.NetworkProxyOptions}"
                                      ItemTemplate="{StaticResource ProgramSettingsNetworkProxyOptionTemplate}"
                                      SelectedItem="{Binding Workspace.SelectedNetworkProxyOption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Grid Margin="0,10,0,0"
                                  Style="{StaticResource ProgramSettingsVisibleWhenTrueStyle}"
                                  DataContext="{Binding Workspace.IsCustomNetworkProxySelected}">
                                <TextBox MinHeight="42"
                                         Padding="12,0"
                                         VerticalContentAlignment="Center"
                                         AutomationProperties.AutomationId="ProgramSettings.CustomNetworkProxyUri"
                                         DataContext="{Binding DataContext.Workspace, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                         Text="{Binding CustomNetworkProxyUri, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                <TextBlock DataContext="{Binding DataContext.Workspace, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           Text="{Binding CustomNetworkProxyPlaceholder}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource ProgramSettingsInputPlaceholderTextStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasCustomNetworkProxyUri}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="4"
                            Grid.ColumnSpan="3"
                            Margin="0,14,0,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0">
                        <DockPanel LastChildFill="False">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        DockPanel.Dock="Right">
                                <ToggleButton x:Name="ThemeToggleButton"
                                              Margin="0,0,12,0"
                                              AutomationProperties.AutomationId="ProgramSettings.ThemeToggle"
                                              AutomationProperties.Name="{Binding Workspace.ThemeSelectionTitle}"
                                              ToolTip="{Binding Workspace.ThemeSelectionTitle}"
                                              IsChecked="{Binding Workspace.IsDarkTheme, Mode=TwoWay}"
                                              Style="{StaticResource ProgramSettingsThemeToggleButtonStyle}"
                                              Checked="ThemeToggleButton_OnChecked"
                                              Unchecked="ThemeToggleButton_OnUnchecked"
                                              Loaded="ThemeToggleButton_OnLoaded">
                                    <Grid Width="56"
                                          Height="56">
                                        <Ellipse x:Name="ThemeToggleGlow"
                                                 Width="48"
                                                 Height="26"
                                                 Margin="0,0,0,7"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Bottom"
                                                 Opacity="0"
                                                 RenderTransformOrigin="0.5,0.5">
                                            <Ellipse.Fill>
                                                <RadialGradientBrush Center="0.5,0.5"
                                                                     GradientOrigin="0.5,0.5"
                                                                     RadiusX="0.56"
                                                                     RadiusY="0.5">
                                                    <GradientStop Color="#66FFD782"
                                                                  Offset="0" />
                                                    <GradientStop Color="#22FFB14A"
                                                                  Offset="0.62" />
                                                    <GradientStop Color="#00FFB14A"
                                                                  Offset="1" />
                                                </RadialGradientBrush>
                                            </Ellipse.Fill>
                                            <Ellipse.RenderTransform>
                                                <TransformGroup>
                                                    <ScaleTransform ScaleX="0.68"
                                                                    ScaleY="0.56" />
                                                    <TranslateTransform Y="5" />
                                                </TransformGroup>
                                            </Ellipse.RenderTransform>
                                        </Ellipse>
                                        <TextBlock x:Name="ThemeSunIcon"
                                                   FontFamily="Segoe Fluent Icons"
                                                   FontSize="20"
                                                   Foreground="{DynamicResource AccentStrongBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Text="&#xE706;"
                                                   RenderTransformOrigin="0.5,0.5">
                                            <TextBlock.RenderTransform>
                                                <TransformGroup>
                                                    <ScaleTransform ScaleX="1"
                                                                    ScaleY="1" />
                                                    <TranslateTransform X="0"
                                                                        Y="0" />
                                                </TransformGroup>
                                            </TextBlock.RenderTransform>
                                        </TextBlock>
                                        <TextBlock x:Name="ThemeMoonIcon"
                                                   FontFamily="Segoe Fluent Icons"
                                                   FontSize="20"
                                                   Foreground="{DynamicResource AccentStrongBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Opacity="0"
                                                   Text="&#xE708;"
                                                   RenderTransformOrigin="0.5,0.5">
                                            <TextBlock.RenderTransform>
                                                <TransformGroup>
                                                    <ScaleTransform ScaleX="0.82"
                                                                    ScaleY="0.82" />
                                                    <TranslateTransform X="-2"
                                                                        Y="18" />
                                                </TransformGroup>
                                            </TextBlock.RenderTransform>
                                        </TextBlock>
                                    </Grid>
                                </ToggleButton>

                                <Button Width="56"
                                        Height="56"
                                        Padding="0"
                                        AutomationProperties.AutomationId="ProgramSettings.AboutButton"
                                        AutomationProperties.Name="{DynamicResource SettingsAboutButton}"
                                        ToolTip="{DynamicResource SettingsAboutButton}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding About.OpenCommand}">
                                    <Border Width="28"
                                            Height="28"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="{DynamicResource HighlightSurfaceBrush}"
                                            BorderBrush="{DynamicResource StrongBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="14">
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontFamily="Segoe UI Semibold"
                                                   FontSize="15"
                                                   Foreground="{DynamicResource AccentStrongBrush}"
                                                   Text="i" />
                                    </Border>
                                </Button>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
