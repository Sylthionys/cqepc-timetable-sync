<UserControl x:Class="CQEPC.TimetableSync.Presentation.Wpf.Views.CourseEditorOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="CourseEditorShellStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
            <Setter Property="MaxWidth" Value="1080" />
            <Setter Property="MaxHeight" Value="780" />
            <Setter Property="Padding" Value="26" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="CornerRadius" Value="30" />
            <Setter Property="Effect" Value="{StaticResource PopupShadowEffect}" />
        </Style>
        <Style x:Key="CourseEditorSectionStyle" TargetType="Border" BasedOn="{StaticResource PanelBorderStyle}">
            <Setter Property="Padding" Value="18" />
            <Setter Property="CornerRadius" Value="22" />
        </Style>
        <Style x:Key="CourseEditorFieldLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource EyebrowTextStyle}">
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="CourseEditorTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="14,11" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>
        <Style x:Key="CourseEditorPreviewCardStyle" TargetType="Border" BasedOn="{StaticResource CourseEditorSectionStyle}">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource CourseEditorShellStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Style="{StaticResource EyebrowTextStyle}" Text="{Binding Title}" />
                    <TextBlock Margin="0,10,0,0"
                               FontSize="30"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               Text="{Binding PreviewTitle}" />
                    <TextBlock Margin="0,12,0,0"
                               Foreground="{DynamicResource SubtleTextBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding Summary}" />
                </StackPanel>

                <Border Grid.Column="1"
                        Margin="20,0,0,0"
                        Style="{StaticResource CourseEditorPreviewCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource EyebrowTextStyle}" Text="{DynamicResource ImportPreviewScopeTitle}" />
                        <TextBlock Margin="0,10,0,0"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}"
                                   Text="{Binding RepeatSummary}" />
                        <TextBlock Margin="0,10,0,0"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="{Binding OccurrenceCountSummary}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,16,0,0"
                    Padding="12"
                    Background="{DynamicResource DangerSurfaceBrush}"
                    BorderBrush="{DynamicResource DangerBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Visibility="{Binding HasValidationMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Foreground="{DynamicResource DangerBrush}" TextWrapping="Wrap" Text="{Binding ValidationMessage}" />
            </Border>

            <Grid Grid.Row="2" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Style="{StaticResource CourseEditorSectionStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource EyebrowTextStyle}" Text="{DynamicResource CourseEditorNameLabel}" />
                                <TextBox Margin="0,10,0,0"
                                         Style="{StaticResource CourseEditorTextBoxStyle}"
                                         FontSize="24"
                                         FontWeight="SemiBold"
                                         Text="{Binding CourseTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <Grid Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Style="{StaticResource CourseEditorFieldLabelStyle}" Text="{DynamicResource CourseEditorLocationLabel}" />
                                        <TextBox Style="{StaticResource CourseEditorTextBoxStyle}"
                                                 Text="{Binding Location, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource CourseEditorFieldLabelStyle}" Text="{DynamicResource CourseEditorNotesLabel}" />
                                        <TextBox MinHeight="96"
                                                 Style="{StaticResource CourseEditorTextBoxStyle}"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 Text="{Binding Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,18,0,0" Style="{StaticResource CourseEditorSectionStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource EyebrowTextStyle}" Text="{DynamicResource CourseEditorRepeatLabel}" />
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Command="{Binding SelectNoneRepeatCommand}"
                                            Content="{DynamicResource CourseEditorRepeatNone}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                <Setter Property="Padding" Value="14,12" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRepeatNoneSelected}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                        <Setter Property="Foreground" Value="White" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <Button Grid.Column="2"
                                            Command="{Binding SelectWeeklyRepeatCommand}"
                                            Content="{DynamicResource CourseEditorRepeatWeekly}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                <Setter Property="Padding" Value="14,12" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRepeatWeeklySelected}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                        <Setter Property="Foreground" Value="White" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <Button Grid.Column="4"
                                            Command="{Binding SelectBiweeklyRepeatCommand}"
                                            Content="{DynamicResource CourseEditorRepeatBiweekly}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                <Setter Property="Padding" Value="14,12" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRepeatBiweeklySelected}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                        <Setter Property="Foreground" Value="White" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>

                                <Grid Margin="0,18,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Style="{StaticResource CourseEditorFieldLabelStyle}" Text="{DynamicResource CourseEditorStartDateLabel}" />
                                        <DatePicker SelectedDate="{Binding StartDate, Mode=TwoWay}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource CourseEditorFieldLabelStyle}" Text="{DynamicResource CourseEditorEndDateLabel}" />
                                        <DatePicker SelectedDate="{Binding EndDate, Mode=TwoWay}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Margin="0,16,0,0">
                                        <TextBlock Style="{StaticResource CourseEditorFieldLabelStyle}" Text="{DynamicResource CourseEditorStartTimeLabel}" />
                                        <TextBox Style="{StaticResource CourseEditorTextBoxStyle}"
                                                 Text="{Binding StartTimeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,16,0,0">
                                        <TextBlock Style="{StaticResource CourseEditorFieldLabelStyle}" Text="{DynamicResource CourseEditorEndTimeLabel}" />
                                        <TextBox Style="{StaticResource CourseEditorTextBoxStyle}"
                                                 Text="{Binding EndTimeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource CourseEditorPreviewCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource EyebrowTextStyle}" Text="{DynamicResource CourseEditorRepeatLabel}" />
                            <TextBlock Margin="0,8,0,0" FontSize="20" FontWeight="SemiBold" Text="{Binding RepeatSummary}" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,14,0,0" Style="{StaticResource CourseEditorPreviewCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource EyebrowTextStyle}" Text="{DynamicResource CourseEditorStartDateLabel}" />
                            <TextBlock Margin="0,8,0,0" FontSize="18" FontWeight="SemiBold" Text="{Binding DateRangeSummary}" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,14,0,0" Style="{StaticResource CourseEditorPreviewCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource EyebrowTextStyle}" Text="{DynamicResource CourseEditorStartTimeLabel}" />
                            <TextBlock Margin="0,8,0,0" FontSize="18" FontWeight="SemiBold" Text="{Binding TimeRangeSummary}" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,14,0,0" Style="{StaticResource CourseEditorPreviewCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource EyebrowTextStyle}" Text="{DynamicResource CourseEditorLocationLabel}" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Text="{Binding LocationSummary}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="3" Margin="0,20,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CancelCommand}" Content="{DynamicResource AboutCloseButton}" />
                <Button Margin="10,0,0,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding ResetCommand}"
                        Content="{DynamicResource CourseEditorResetButton}"
                        Visibility="{Binding CanReset, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <Button Margin="10,0,0,0" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveCommand}" Content="{DynamicResource CourseEditorSaveButton}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

