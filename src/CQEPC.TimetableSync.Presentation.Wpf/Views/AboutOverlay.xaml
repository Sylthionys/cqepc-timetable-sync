<UserControl x:Class="CQEPC.TimetableSync.Presentation.Wpf.Views.AboutOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AutomationProperties.AutomationId="AboutOverlay.Root">
    <UserControl.Resources>
        <Style x:Key="AboutPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="32" />
            <Setter Property="Padding" Value="28" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="14" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             To="1"
                                             Duration="0:0:0.24"
                                             EasingFunction="{StaticResource StandardEase}" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                             To="0"
                                             Duration="0:0:0.24"
                                             EasingFunction="{StaticResource StrongEase}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AboutInsetStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="AboutTagStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
        </Style>
    </UserControl.Resources>

    <Grid Style="{StaticResource PageRootStyle}"
          RenderTransformOrigin="0.5,0.5">
        <Grid>
            <Ellipse Width="440"
                     Height="440"
                     Margin="-160,-160,0,0"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Fill="{DynamicResource AccentSoftBrush}"
                     Opacity="0.26"
                     IsHitTestVisible="False" />
            <Ellipse Width="320"
                     Height="320"
                     Margin="0,0,-110,-130"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Bottom"
                     Fill="{DynamicResource AccentMutedBrush}"
                     Opacity="0.72"
                     IsHitTestVisible="False" />
        </Grid>

        <Border Width="580"
                MaxWidth="580"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Style="{StaticResource AboutPanelStyle}"
                Effect="{StaticResource PopupShadowEffect}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource EyebrowTextStyle}"
                                   Text="{DynamicResource SettingsAboutButton}" />
                        <TextBlock Margin="0,10,0,0"
                                   FontSize="31"
                                   FontWeight="SemiBold"
                                   Text="{Binding Title}" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   Text="{Binding Version}" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            AutomationProperties.AutomationId="AboutOverlay.Close"
                            MinWidth="92"
                            Height="40"
                            VerticalAlignment="Top"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding CloseCommand}"
                            Content="{DynamicResource AboutCloseButton}" />
                </Grid>

                <Border Grid.Row="1"
                        Margin="0,18,0,0"
                        Padding="18"
                        Background="{DynamicResource HighlightSurfaceBrush}"
                        BorderBrush="{DynamicResource StrongBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="22">
                    <TextBlock TextWrapping="Wrap"
                               AutomationProperties.AutomationId="AboutOverlay.SummaryText"
                               LineHeight="22"
                               Text="{Binding Summary}" />
                </Border>

                <Border Grid.Row="2"
                        Margin="0,16,0,0"
                        Style="{StaticResource AboutInsetStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource EyebrowTextStyle}"
                                   Text="{DynamicResource AboutOperatingModelTitle}" />
                        <TextBlock Margin="0,10,0,0"
                                   AutomationProperties.AutomationId="AboutOverlay.PhilosophyText"
                                   TextWrapping="Wrap"
                                   LineHeight="22"
                                   Text="{Binding Philosophy}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="3"
                        Margin="0,16,0,0"
                        Style="{StaticResource AboutInsetStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource EyebrowTextStyle}"
                                   Text="{DynamicResource AboutTargetsTitle}" />
                        <TextBlock Margin="0,10,0,0"
                                   AutomationProperties.AutomationId="AboutOverlay.ProvidersText"
                                   TextWrapping="Wrap"
                                   LineHeight="22"
                                   Text="{Binding Providers}" />
                        <WrapPanel Margin="0,18,0,0">
                            <Border Style="{StaticResource AboutTagStyle}">
                                <TextBlock Foreground="{DynamicResource SubtleTextBrush}"
                                           Text="{DynamicResource AboutTagLocalFirst}" />
                            </Border>
                            <Border Style="{StaticResource AboutTagStyle}">
                                <TextBlock Foreground="{DynamicResource SubtleTextBrush}"
                                           Text="{DynamicResource AboutTagPreviewFirst}" />
                            </Border>
                            <Border Style="{StaticResource AboutTagStyle}">
                                <TextBlock Foreground="{DynamicResource SubtleTextBrush}"
                                           Text="{DynamicResource AboutTagProviderAware}" />
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>

