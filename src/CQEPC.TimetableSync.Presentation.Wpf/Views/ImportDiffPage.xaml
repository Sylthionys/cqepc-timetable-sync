                        </WrapPanel>

                        <WrapPanel DockPanel.Dock="Right"
                                   Visibility="{Binding ElementName=ImportLayoutRoot, Path=Tag, Converter={StaticResource AdaptiveModeVisibilityConverter}, ConverterParameter='Medium|Expanded'}">
                            <Button Margin="8,0,0,0"
                                    AutomationProperties.AutomationId="Import.Toggle.SelectedOnly"
                                    Style="{StaticResource ImportGhostButtonStyle}"
                                    Command="{Binding ToggleSelectedOnlyCommand}"
                                    Content="{Binding ToggleSelectedOnlyLabel}" />
                        </WrapPanel>
                    </DockPanel>
                </Border>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
