                                           Style="{StaticResource ImportBodyTextStyle}"
                                           Text="{Binding TeacherText}"
                                           Visibility="{Binding ElementName=ImportLayoutRoot, Path=Tag, Converter={StaticResource AdaptiveModeVisibilityConverter}, ConverterParameter=Expanded}" />
                            </WrapPanel>
                            <WrapPanel Grid.Column="1"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center">
                                <Border Margin="0,0,8,0"
                                        Style="{StaticResource ImportChipStyle}"
                                        Background="{Binding PrimaryStatusBackground}">
                                    <TextBlock FontSize="11"
                                               Foreground="{Binding PrimaryStatusForeground}"
                                               Text="{Binding PrimaryStatusText}" />
                                </Border>
                                <ItemsControl ItemsSource="{Binding ChangeBadges}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,8,0"
                                                    Style="{StaticResource ImportChipStyle}"
                                                    Background="{Binding Background}">
                                                <TextBlock FontSize="11"
                                                           Foreground="{Binding Foreground}"
                                                           Text="{Binding Text}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock FontSize="18"
                                           Foreground="{StaticResource ImportPageSubtleTextBrush}"
                                           Text="&#x203A;" />
