                                    Visibility="{Binding ShowCourseEditorPendingActions, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <Button Margin="0,0,8,0"
                                    Style="{StaticResource ImportGhostButtonCompactStyle}"
                                    Command="{Binding SyncCurrentCalendarCommand}"
                                    Content="{Binding HeaderSecondaryActionText}" />
                            <Button Margin="0,0,8,0"
                                    Style="{StaticResource ImportGhostButtonCompactStyle}"
                                    Command="{Binding SelectAllCommand}"
                                    Content="{x:Static resources:UiText.ImportSelectAllButton}" />
                            <Button Margin="0,0,8,0"
                                    Style="{StaticResource ImportGhostButtonCompactStyle}"
                                    Command="{Binding ClearAllCommand}"
