                        </WrapPanel>
                        <WrapPanel HorizontalAlignment="Right"
                                   Visibility="{Binding ElementName=ImportLayoutRoot, Path=Tag, Converter={StaticResource AdaptiveModeVisibilityConverter}, ConverterParameter=Medium}">
