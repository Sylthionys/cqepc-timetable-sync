<UserControl x:Class="CQEPC.TimetableSync.Presentation.Wpf.Views.ImportDiffPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:CQEPC.TimetableSync.Presentation.Wpf.Controls"
             xmlns:resources="clr-namespace:CQEPC.TimetableSync.Presentation.Wpf.Resources"
             xmlns:views="clr-namespace:CQEPC.TimetableSync.Presentation.Wpf.Views"
             AutomationProperties.AutomationId="Import.PageRoot"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="ImportSectionBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ImportPageSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ImportPageBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
        </Style>

        <Style x:Key="ImportSubtleBorderStyle" TargetType="Border" BasedOn="{StaticResource ImportSectionBorderStyle}">
            <Setter Property="Background" Value="{StaticResource ImportPageSurfaceAltBrush}" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>

        <Style x:Key="ImportTitleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ImportPageTextBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="ImportBodyTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ImportPageSubtleTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <DataTemplate x:Key="ImportTimeZoneOptionTemplate">
            <TextBlock VerticalAlignment="Center"
                       Text="{Binding DisplayName}" />
        </DataTemplate>

        <DataTemplate x:Key="ImportCalendarColorOptionTemplate">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="12"
                         Height="12"
                         Margin="0,0,8,0"
                         VerticalAlignment="Center"
                         Fill="{Binding ColorHex}"
                         Stroke="{DynamicResource BorderBrush}"
                         StrokeThickness="1" />
                <TextBlock VerticalAlignment="Center"
                           Text="{Binding DisplayName}" />
            </StackPanel>
        </DataTemplate>

        <Style x:Key="ImportMetricCardStyle" TargetType="Border" BasedOn="{StaticResource ImportSubtleBorderStyle}">
            <Setter Property="Padding" Value="12,11" />
            <Setter Property="MinWidth" Value="124" />
        </Style>

        <DataTemplate x:Key="ImportDetailLineTemplate">
            <TextBlock Margin="0,0,0,8"
                       Style="{StaticResource ImportBodyTextStyle}"
                       Text="{Binding}" />
        </DataTemplate>

        <DataTemplate x:Key="ImportDetailFieldTemplate">
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           MinWidth="72"
                           Style="{StaticResource ImportBodyTextStyle}"
                           Text="{Binding Label}" />
                <TextBlock Grid.Column="2"
                           Foreground="{StaticResource ImportPageTextBrush}"
                           FontSize="13"
                           Text="{Binding Value}"
                           TextWrapping="Wrap" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ImportTextDiffLineTemplate">
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border x:Name="BeforeCell"
                        Grid.Column="0"
                        Padding="8,5"
                        Background="{StaticResource ImportPageTrackBrush}"
                        CornerRadius="8">
                    <Grid>
                        <TextBlock x:Name="BeforeText"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Foreground="{StaticResource ImportPageSubtleTextBrush}"
                                   Text="{Binding BeforeDisplayText}"
                                   TextWrapping="Wrap" />
                        <TextBox x:Name="BeforeEditor"
                                 AutomationProperties.AutomationId="Import.Detail.GoogleNotesEditor"
                                 MinHeight="26"
                                 MaxHeight="84"
                                 Padding="6,3"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding EditableText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="Collapsed" />
                    </Grid>
                </Border>
                <Border x:Name="AfterCell"
                        Grid.Column="2"
                        Padding="8,5"
                        Background="{StaticResource ImportPageTrackBrush}"
                        CornerRadius="8">
                    <Grid>
                        <TextBlock x:Name="AfterText"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Foreground="{StaticResource ImportPageSubtleTextBrush}"
                                   Text="{Binding AfterDisplayText}"
                                   TextWrapping="Wrap" />
                        <TextBox x:Name="AfterEditor"
                                 AutomationProperties.AutomationId="Import.Detail.GoogleNotesEditor"
                                 MinHeight="26"
                                 MaxHeight="84"
                                 Padding="6,3"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding EditableText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="Collapsed" />
                    </Grid>
                </Border>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsChangedLine}" Value="False">
                    <Setter TargetName="BeforeCell" Property="Grid.ColumnSpan" Value="3" />
                    <Setter TargetName="AfterCell" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="BeforeCell" Property="Background" Value="{StaticResource ImportPageTrackBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsDeletedLine}" Value="True">
                    <Setter TargetName="BeforeCell" Property="Grid.ColumnSpan" Value="3" />
                    <Setter TargetName="BeforeCell" Property="Background" Value="{StaticResource ImportDeleteSurfaceBrush}" />
                    <Setter TargetName="AfterCell" Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsAddedLine}" Value="True">
                    <Setter TargetName="BeforeCell" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="AfterCell" Property="Grid.Column" Value="0" />
                    <Setter TargetName="AfterCell" Property="Grid.ColumnSpan" Value="3" />
                    <Setter TargetName="AfterCell" Property="Background" Value="{StaticResource ImportAddSurfaceBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CanInlineEdit}" Value="True">
                    <Setter TargetName="BeforeText" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="AfterText" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="BeforeEditor" Property="Visibility" Value="Visible" />
                    <Setter TargetName="AfterEditor" Property="Visibility" Value="Visible" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <Style x:Key="ImportWorkflowStepBadgeStyle" TargetType="Border">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="BorderBrush" Value="{StaticResource ImportPageBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{StaticResource ImportPageSurfaceAltBrush}" />
            <Setter Property="Opacity" Value="0.9" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding State}" Value="Completed">
                    <Setter Property="Background" Value="{StaticResource ImportPageSelectionBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource ImportPageSelectionBrush}" />
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Active">
                    <Setter Property="Background" Value="{StaticResource ImportPageSelectionBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource ImportPageSelectionBrush}" />
                    <Setter Property="Opacity" Value="1" />
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0.45"
                                                 To="1"
                                                 Duration="0:0:0.18"
                                                 EasingFunction="{StaticResource StrongEase}" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ImportWorkflowConnectorStyle" TargetType="Border">
            <Setter Property="Height" Value="2" />
            <Setter Property="Background" Value="{StaticResource ImportPageBorderBrush}" />
            <Setter Property="Opacity" Value="0.8" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ConnectorState}" Value="Completed">
                    <Setter Property="Background" Value="{StaticResource ImportPageSelectionBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ConnectorState}" Value="Active">
                    <Setter Property="Background" Value="{StaticResource ImportPageSelectionBrush}" />
                    <Setter Property="Opacity" Value="0.55" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ImportChipStyle" TargetType="Border">
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Background" Value="{StaticResource ImportNeutralSurfaceBrush}" />
        </Style>

        <Style x:Key="ImportGhostButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource ImportPageTextBrush}" />
            <Setter Property="Background" Value="{StaticResource ImportPageSurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ImportPageBorderBrush}" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="MinHeight" Value="36" />
        </Style>

        <Style x:Key="ImportGhostButtonCompactStyle" TargetType="Button" BasedOn="{StaticResource ImportGhostButtonStyle}">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="ImportPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{StaticResource ImportPageSelectionBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ImportPageSelectionBrush}" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="MinHeight" Value="36" />
        </Style>

        <Style x:Key="ImportPrimaryButtonCompactStyle" TargetType="Button" BasedOn="{StaticResource ImportPrimaryButtonStyle}">
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="ImportModeToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Padding" Value="11,5" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Background" Value="{StaticResource ImportPageSurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ImportPageBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource ImportPageSubtleTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="999">
                            <ContentPresenter Margin="0"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="{StaticResource ImportPageSelectionBrush}" />
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource ImportPageSelectionBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource ImportPageTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ImportInfoButtonStyle" TargetType="Button" BasedOn="{StaticResource ImportGhostButtonStyle}">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Content" Value="i" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="MinHeight" Value="36" />
        </Style>

        <Style x:Key="ImportFlatActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OverlayDismissButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ImportToolbarComboItemStyle" TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="TextBlock.TextAlignment" Value="Left" />
        </Style>

        <Style x:Key="ImportToolbarComboStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Background" Value="{StaticResource ImportPageSurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ImportPageBorderBrush}" />
            <Setter Property="Foreground" Value="{StaticResource ImportPageTextBrush}" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="TextBlock.TextAlignment" Value="Left" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource ImportToolbarComboItemStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="14"
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                      IsHitTestVisible="False" />
                                    <ToggleButton x:Name="DropDownToggle"
                                                  ClickMode="Press"
                                                  Background="Transparent"
                                                  Focusable="False"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="Fade">
                                <Border x:Name="PopupBorder"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Margin="0,8,0,0"
                                        Padding="8"
                                        Background="{DynamicResource PopupSurfaceBrush}"
                                        BorderBrush="{StaticResource ImportPageBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Effect="{StaticResource PopupShadowEffect}">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="PopupBorder" Property="MinHeight" Value="56" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource ImportPageSelectionBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource ImportPageSelectionBrush}" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource ImportPageSurfaceBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource ImportPageSelectionBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.46" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ImportToolbarComboCompactStyle" TargetType="ComboBox" BasedOn="{StaticResource ImportToolbarComboStyle}">
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="9,4" />
        </Style>

        <Style x:Key="ImportToolbarTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Background" Value="{StaticResource ImportPageSurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ImportPageBorderBrush}" />
            <Setter Property="Foreground" Value="{StaticResource ImportPageTextBrush}" />
        </Style>

        <Style x:Key="ImportToolbarTextBoxCompactStyle" TargetType="TextBox" BasedOn="{StaticResource ImportToolbarTextBoxStyle}">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="9,4" />
        </Style>

        <Style x:Key="ImportEditorTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="MinLines" Value="1" />
            <Setter Property="MaxLines" Value="3" />
        </Style>

        <Style x:Key="ImportEditorTimeTextBoxStyle" TargetType="controls:TimeTextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ImportCheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="Foreground" Value="{StaticResource ImportPageTextBrush}" />
        </Style>

        <Style x:Key="ImportExpanderStyle" TargetType="Expander">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid Margin="0"
                                      Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="0" />
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="HeaderToggle"
                                                  Grid.ColumnSpan="2"
                                                  Margin="0"
                                                  Padding="0"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Focusable="False"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter Grid.Column="0"
                                                      Margin="0"
                                                      ContentSource="Header" />
                                    <TextBlock x:Name="HeaderToggleGlyph"
                                               Grid.Column="1"
                                               Margin="0,8,8,8"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="18"
                                               Foreground="{StaticResource ImportPageSubtleTextBrush}"
                                               IsHitTestVisible="False"
                                               Visibility="Collapsed"
                                               Text="&#x2304;" />
                                </Grid>
                                <ContentPresenter x:Name="ExpandSite"
                                                  Grid.Row="1"
                                                  Visibility="Collapsed" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                                <Setter TargetName="HeaderToggleGlyph" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="180" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger SourceName="HeaderToggle" Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource ImportPageSurfaceMutedBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource ImportPageSelectionBrush}" />
                                <Setter TargetName="HeaderToggleGlyph" Property="Foreground" Value="{StaticResource ImportPageTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ImportCourseExpanderStyle" TargetType="Expander" BasedOn="{StaticResource ImportExpanderStyle}">
            <Setter Property="Background" Value="{StaticResource ImportPageSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ImportPageBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="ImportOccurrenceCardBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="10" />
            <Setter Property="Background" Value="{StaticResource ImportPageTrackBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ImportPageBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsAdded}" Value="True">
                    <Setter Property="Background" Value="{StaticResource ImportAddSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource ImportAddBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsUpdated}" Value="True">
                    <Setter Property="Background" Value="{StaticResource ImportUpdateSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource ImportUpdateBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                    <Setter Property="Background" Value="{StaticResource ImportDeleteSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource ImportDeleteBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsConflict}" Value="True">
                    <Setter Property="Background" Value="{StaticResource ImportConflictSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource ImportConflictBrush}" />
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource ImportPageSelectionBrush}" />
                </Trigger>
                <DataTrigger Binding="{Binding IsActiveSelection}" Value="True">
                    <Setter Property="Background" Value="{StaticResource ImportPageSurfaceMutedBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource ImportPageSelectionBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ImportRuleExpanderStyle" TargetType="Expander" BasedOn="{StaticResource ImportExpanderStyle}">
            <Setter Property="Background" Value="{StaticResource ImportPageSurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ImportPageBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsAdded}" Value="True">
                    <Setter Property="Background" Value="{StaticResource ImportAddSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource ImportAddBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsUpdated}" Value="True">
                    <Setter Property="Background" Value="{StaticResource ImportUpdateSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource ImportUpdateBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                    <Setter Property="Background" Value="{StaticResource ImportDeleteSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource ImportDeleteBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsConflict}" Value="True">
                    <Setter Property="Background" Value="{StaticResource ImportConflictSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource ImportConflictBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="ImportOccurrenceRowTemplate">
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0"
                          Margin="0,10,0,0"
                          VerticalAlignment="Top"
                          Style="{StaticResource ImportCheckBoxStyle}"
                          AutomationProperties.AutomationId="{Binding ToggleAutomationId}"
                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="2"
                        Style="{StaticResource ImportFlatActionButtonStyle}"
                        AutomationProperties.AutomationId="{Binding SelectAutomationId}"
                        Command="{Binding DataContext.SelectOccurrenceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}">
